---
import Base from '../layouts/Base.astro';
---

<Base title="Page not found — ReARM">
  <section class="nf">
    <div class="container">
      <div class="eyebrow">404</div>
      <h1>Page not found</h1>
      <p>The page you are looking for does not exist or has moved.</p>
      <a class="btn btn--navy" href="/">Back to home</a>
    </div>
  </section>
</Base>

<style>
  .nf { padding: 96px 0 120px; }
  .nf h1 { font-size: 45px; font-weight: 700; letter-spacing: -0.02em; margin: 16px 0 14px; }
  .nf p { font-size: 16px; color: var(--body-2); margin-bottom: 28px; }
</style>
