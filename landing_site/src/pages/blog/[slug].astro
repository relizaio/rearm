---
import Base from '../../layouts/Base.astro';
import PostArticle from '../../components/PostArticle.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((p) => ({ params: { slug: p.id }, props: { post: p } }));
}
const { post } = Astro.props;
const { Content } = await render(post);
---

<Base title={`${post.data.title} - ReARM Blog`} active="blog" ogImage={post.data.ogImage}>
  <PostArticle title={post.data.title} date={post.data.date} backHref="/blog/" backLabel="Blog">
    <Content />
  </PostArticle>
</Base>
