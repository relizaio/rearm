# Copy to .env (same directory as docker-compose.yml) to configure the
# deployment. All values have working localhost defaults, so this file
# is only needed to customize -- e.g. non-local hosts, OCI storage, or
# non-default passwords. Note: .env files here are gitignored; keep it
# that way and consider chmod 600, since this file carries credentials.

# --- External origin ---

# Externally visible host:port of the ReARM UI -- the single origin the
# browser talks to (the UI reverse-proxies Keycloak under /kauth, so no
# other port needs to be reachable from outside). Must match what users
# type in the browser, e.g. rearm.example.com or an IP:port.
# NB: the Keycloak realm import happens on first boot only -- changing
# REARM_HOST later requires wiping the keycloak volume (docker compose
# down -v; destroys users) or editing the login-app client in the
# Keycloak admin console.
#REARM_HOST=rearm.example.com

# Protocol of the external origin. Any non-localhost deployment must use
# https (browsers only expose the Web Crypto API, which the login flow
# requires, in secure contexts) -- enable the tls profile below.
#REARM_PROTOCOL=https

# --- TLS front (traefik) ---
# Enable with: docker compose --profile tls up -d
# (or set COMPOSE_PROFILES=tls in this file to make plain
# "docker compose up -d" include it.)
#COMPOSE_PROFILES=tls

# Without REARM_ACME_EMAIL, traefik serves a self-signed certificate --
# browser warning, fine for IP-based evals. With REARM_ACME_EMAIL set
# and a real REARM_TLS_HOST domain on default ports (443/80 reachable
# from the internet), certificates come from Let's Encrypt.
#REARM_TLS_HOST=rearm.example.com
#REARM_ACME_EMAIL=you@example.com

# Host ports for the TLS front. Non-default ports are fine for
# self-signed evals (set REARM_HOST to match, e.g. 203.0.113.7:8443)
# but break the ACME challenge and the http->https redirect target.
#REARM_TLS_PORT=443
#REARM_TLS_HTTP_PORT=80

# --- OCI artifact storage (optional) ---
# For a bundled local registry instead of an external one, start with the
# zot overlay (no variables required; see README "OCI artifact storage"):
#   docker compose -f docker-compose.yml -f docker-compose.zot.yml up -d
# Credentials for OCI storage of BOMs/artifacts. Replaces the legacy
# core.env / oci.env / rebom.env files (still honored for backward
# compatibility; these variables take effect via the compose file).

# Registry namespace/project, referenced by both the backend and rebom.
#OCI_REGISTRY_NAMESPACE=430fcdde-d7bc-4542-ad5b-4f534f4942f0-private
#OCI_REGISTRY_HOST=registry.relizahub.com
#OCI_REGISTRY_USERNAME=myusername
#OCI_REGISTRY_TOKEN=mypassword

# --- Database passwords ---
# Each service has its own PostgreSQL instance; passwords can differ.
# Change these before exposing anything beyond localhost.
#REARM_PG_PASS=relizaPass
#KEYCLOAK_PG_PASS=relizaPass
#REBOM_PG_PASS=relizaPass

# --- Misc ---

# Interface for the main PostgreSQL convenience port (5440). Loopback by
# default; set to 0.0.0.0 only if you need remote DB access and have
# changed REARM_PG_PASS.
#REARM_PG_BIND=127.0.0.1
