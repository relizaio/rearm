# Copy to .env (same directory as docker-compose.yml) to run ReARM on a
# host other than localhost. All values have working localhost defaults,
# so this file is only needed for non-local deployments.

# Externally visible host:port of the ReARM UI -- the single origin the
# browser talks to (the UI reverse-proxies Keycloak under /kauth, so no
# other port needs to be reachable from outside). Must match what users
# type in the browser, e.g. rearm.example.com:8092 or an IP:port.
#REARM_HOST=rearm.example.com:8092

# Protocol of the external origin. Set to https when a reverse proxy or
# load balancer in front of port 8092 terminates TLS. The compose stack
# itself serves plain http.
#REARM_PROTOCOL=http

# Interface for the PostgreSQL convenience port (5440). Loopback by
# default because the database ships with a well-known default password.
# Set to 0.0.0.0 only if you need remote DB access and have changed the
# password.
#REARM_PG_BIND=127.0.0.1

# --- TLS profile (docker compose --profile tls up -d) ---
# Host port for HTTPS (published to caddy's 443).
#REARM_TLS_PORT=443
# Host port for the ACME http challenge / http->https redirect.
#REARM_TLS_HTTP_PORT=80
# Caddy site address: ":443" answers any host with a self-signed cert
# (IP-based evals); "https://rearm.example.com" for a real domain.
#REARM_SITE_ADDRESS=:443
# "internal" for self-signed; an email address enables Let's Encrypt.
#REARM_TLS_CONFIG=you@example.com
