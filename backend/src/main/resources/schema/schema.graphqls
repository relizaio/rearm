}

type AggregatedChangelog {
	componentUuid: ID!
	componentName: String!
	orgUuid: ID!
	firstRelease: ReleaseInfo!
	lastRelease: ReleaseInfo!
	branches: [AggregatedBranchChanges!]!
	sbomChanges: SbomChangesWithAttribution!
	findingChanges: FindingChangesWithAttribution!
}

type ReleaseInfo {
	uuid: ID!
	version: String!
	lifecycle: ReleaseLifecycleEnum!
}

type NoneBranchChanges {
	branchUuid: ID!
	branchName: String!
	componentUuid: ID
	componentName: String
	releases: [NoneReleaseChanges!]!
	changeType: ChangeType
}

type AggregatedBranchChanges {
	branchUuid: ID!
	branchName: String!
	componentUuid: ID
	componentName: String
	firstReleaseUuid: ID
	firstVersion: String
	lastReleaseUuid: ID
	lastVersion: String
	commitsByType: [CommitsByType!]!
	changeType: ChangeType
}

