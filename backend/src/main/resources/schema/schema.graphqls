# ========== Sealed Interface Changelog Types ==========

union ComponentChangelog = NoneChangelog | AggregatedChangelog | NoneProductChangelog

type NoneChangelog {
	componentUuid: ID!
	componentName: String!
	orgUuid: ID!
	# firstRelease/lastRelease are nullable on ALL ComponentChangelog members even though only
	# AggregatedChangelog has a null-producing path (the posture empty-window bypass): GraphQL's
	# OverlappingFieldsCanBeMerged rule rejects a merged inline-fragment selection when the same
	# field name has different nullability across union members (FieldsConflict 400, observed live).
	firstRelease: ReleaseInfo
	lastRelease: ReleaseInfo
	branches: [NoneBranchChanges!]!
	"ADDITIVE (board task #37): re-scan-driven finding changes over time, read from finding_change_events. Defaults to empty."
	overTimeFindingChanges: [MetricsRevisionFindingChange!]!
	"ADDITIVE (board task #38, phase 3): effective lower bound the over-time read started at when the requested window was clamped to the retention horizon; null when not clamped."
	overTimeFindingChangesSince: DateTime
}

type NoneProductChangelog {
	componentUuid: ID!
	componentName: String!
	orgUuid: ID!
	firstRelease: ReleaseInfo
	lastRelease: ReleaseInfo
	productReleases: [ProductReleaseChanges!]!
}

type ProductReleaseChanges {
	releaseUuid: ID!
	version: String!
	lifecycle: ReleaseLifecycleEnum!
	createdDate: DateTime!
	branches: [NoneBranchChanges!]!
}

type AggregatedChangelog {
	componentUuid: ID!
	componentName: String!
	orgUuid: ID!
	"Nullable (board task #38, phase 3): null on the empty-window component posture-diff path (no in-window release, posture-only). Always present on the legacy release-anchored path."
	firstRelease: ReleaseInfo
	"Nullable (board task #38, phase 3): null on the empty-window component posture-diff path (no in-window release, posture-only). Always present on the legacy release-anchored path."
	lastRelease: ReleaseInfo
	branches: [AggregatedBranchChanges!]!
	sbomChanges: SbomChangesWithAttribution!
	findingChanges: FindingChangesWithAttribution!
	"ADDITIVE (board task #37): re-scan-driven finding changes over time, read from finding_change_events. Defaults to empty."
	overTimeFindingChanges: [MetricsRevisionFindingChange!]!
	"ADDITIVE (board task #38, phase 3): effective lower bound the over-time read started at when the requested window was clamped to the retention horizon; null when not clamped."
	overTimeFindingChangesSince: DateTime
	"ADDITIVE (board task #38, phase 3): COMPONENT-scope window posture-diff (New/StillPresent/Resolved + attribution + KEV overlay). Populated only when the changelogPostureDiffEnabled flag is on and the component posture-diff path runs; null otherwise. isNewToOrganization at this scope means new-to-component (relabeled by the UI by context)."
	postureFindingChanges: FindingChangesWithAttribution
}

type ReleaseInfo {
	uuid: ID!
	version: String!
	lifecycle: ReleaseLifecycleEnum!
}

type NoneBranchChanges {
	branchUuid: ID!
	branchName: String!
	componentUuid: ID
	componentName: String
	releases: [NoneReleaseChanges!]!
	changeType: ChangeType
}

type AggregatedBranchChanges {
	branchUuid: ID!
	branchName: String!
	componentUuid: ID
	componentName: String
	firstReleaseUuid: ID
	firstVersion: String
	lastReleaseUuid: ID
	lastVersion: String
	commitsByType: [CommitsByType!]!
	changeType: ChangeType
}

type CommitsByType {
	changeType: String!
	commits: [CodeCommit!]!
}

type NoneReleaseChanges {
	releaseUuid: ID!
	version: String!
	lifecycle: ReleaseLifecycleEnum!
	commits: [CodeCommit!]!
	sbomChanges: ReleaseSbomChanges!
	findingChanges: ReleaseFindingChanges!
	createdDate: DateTime!
}

type CodeCommit {
	commitId: String
	commitUri: String
	message: String!
	author: String
	email: String
	changeType: String!
}

type ReleaseSbomArtifact {
	purl: String!
	name: String
	version: String
}

type ReleaseSbomChanges {
	addedArtifacts: [ReleaseSbomArtifact!]!
	removedArtifacts: [ReleaseSbomArtifact!]!
}

type ReleaseVulnerabilityInfo {
	vulnId: String!
	purl: String
	severity: String
	aliases: [VulnerabilityAlias!]
	analysisState: AnalysisState
	"True when this vulnerability (by CVE id or alias) is in the CISA KEV catalog"
	knownExploited: Boolean
}

type ReleaseViolationInfo {
	type: String!
	purl: String
	analysisState: AnalysisState
}

type ReleaseWeaknessInfo {
	cweId: String!
	severity: String
	ruleId: String
	location: String
	analysisState: AnalysisState
}

type ReleaseFindingChanges {
	appearedCount: Int!
	resolvedCount: Int!
	appearedVulnerabilities: [ReleaseVulnerabilityInfo!]!
	resolvedVulnerabilities: [ReleaseVulnerabilityInfo!]!
	appearedViolations: [ReleaseViolationInfo!]!
	resolvedViolations: [ReleaseViolationInfo!]!
	appearedWeaknesses: [ReleaseWeaknessInfo!]!
	resolvedWeaknesses: [ReleaseWeaknessInfo!]!
}

# ========== Organization Changelog Types ==========

union OrganizationChangelog = NoneOrganizationChangelog | AggregatedOrganizationChangelog

type NoneOrganizationChangelog {
	orgUuid: ID!
	dateFrom: DateTime!
	dateTo: DateTime!
	components: [ComponentChangelog!]!
	"ADDITIVE (board task #37): org-wide re-scan-driven finding changes over time, read from finding_change_events. Defaults to empty."
	overTimeFindingChanges: [MetricsRevisionFindingChange!]!
	"ADDITIVE (board task #38, phase 3): effective lower bound the over-time read started at when the requested window was clamped to the retention horizon; null when not clamped."
	overTimeFindingChangesSince: DateTime
}

type AggregatedOrganizationChangelog {
	orgUuid: ID!
	dateFrom: DateTime!
	dateTo: DateTime!
	components: [ComponentChangelog!]!
	sbomChanges: SbomChangesWithAttribution!
	findingChanges: FindingChangesWithAttribution!
	"ADDITIVE (board task #37): org-wide re-scan-driven finding changes over time, read from finding_change_events. Defaults to empty."
	overTimeFindingChanges: [MetricsRevisionFindingChange!]!
	"ADDITIVE (board task #38, phase 3): effective lower bound the over-time read started at when the requested window was clamped to the retention horizon; null when not clamped."
	overTimeFindingChangesSince: DateTime
}

"Kind of re-scan-driven finding change between two consecutive metrics snapshots of the same release (board task #37)."
enum FindingChangeKind {
	APPEARED
	RESOLVED
	SEVERITY_INCREASED
	SEVERITY_DECREASED
	KEV_ADDED
	KEV_REMOVED
}

"""
A single re-scan-driven finding change for one release, bucketed at the date the change took
effect (the metrics_audit revision date, NOT the release creation date). Exactly one of
vulnerability / violation / weakness is non-null. previousSeverity is populated for
SEVERITY_INCREASED and SEVERITY_DECREASED (the pre-change severity).
"""
type MetricsRevisionFindingChange {
	changeDate: DateTime!
	changeKind: FindingChangeKind!
	releaseUuid: ID!
	version: String!
	componentUuid: ID!
	componentName: String!
	"ADDITIVE (board task F7b): the producing branch, so the timeline drawer can distinguish rows that share one component@version."
	branchUuid: ID
	branchName: String
	vulnerability: ReleaseVulnerabilityInfo
	violation: ReleaseViolationInfo
	weakness: ReleaseWeaknessInfo
	previousSeverity: String
}

type ComponentAttribution {
	componentUuid: ID!
	componentName: String!
	releaseUuid: ID!
	releaseVersion: String!
	branchUuid: ID
	branchName: String
}

# Which finding-lifecycle bucket to page in findingAttributionByDate.
enum FindingAttributionBucket { APPEARED, PRESENT, RESOLVED }

# Which finding family the drill-down key belongs to.
enum ChangelogFindingKind { VULNERABILITY, VIOLATION, WEAKNESS }

# One page of a finding's attribution. total is the FULL bucket size (== the *InCount shown inline),
# so the UI can render pagination and "+N more".
type ComponentAttributionPage {
	items: [ComponentAttribution!]!
	total: Int!
	page: Int!
	pageSize: Int!
}

# Read scope for findingChangeTimelineByDate (org-level only). RELEASE_ANCHORED (default) bounds events to
# releases produced in the window; ALL_POSTURE also surfaces re-scan-driven changes on releases produced
# before the window (a newly-disclosed CVE against an already-shipped release). See FindingChangeScope.java.
enum FindingChangeScope {
	RELEASE_ANCHORED
	ALL_POSTURE
}

# One page of the over-time finding-change timeline (findingChangeTimelineByDate). total is the full count;
# since is the retention-clamp lower bound (non-null only when the window predated the retention horizon).
type MetricsRevisionFindingChangePage {
	items: [MetricsRevisionFindingChange!]!
	total: Int!
	page: Int!
	pageSize: Int!
	since: DateTime
	"ADDITIVE (board task F4): true when total is a FLOOR, not the true count -- the org-scope ALL_POSTURE scan hit its row cap, so more events exist than were counted. Render the total as 'N+' and hint to narrow the window. Always false for the release-anchored (default) scope, which is unbounded."
	truncated: Boolean!
}

type VulnerabilityWithAttribution {
	# Opaque handle to page this finding's full attribution via findingAttributionByDate.
	findingKey: String!
	vulnId: String!
	severity: String
	purl: String!
	aliases: [VulnerabilityAlias!]
	# resolvedIn/appearedIn/presentIn are PREVIEW-capped (first few entries) for payload control.
	# The *Count fields are the true totals; when a count exceeds the preview length the UI shows
	# "+N more" and drills down via findingAttributionByDate. See changelog-read-contract-redesign.md.
	resolvedIn: [ComponentAttribution!]!
	appearedIn: [ComponentAttribution!]!
	presentIn: [ComponentAttribution!]!
	resolvedInCount: Int!
	appearedInCount: Int!
	presentInCount: Int!
	isNetResolved: Boolean!
	isNetAppeared: Boolean!
	isStillPresent: Boolean!
	orgContext: OrgLevelContext
	analysisState: AnalysisState
	"True when this vulnerability (by CVE id or alias) is in the CISA KEV catalog"
	knownExploited: Boolean
}

type VulnerabilityAlias {
	aliasId: String!
}

# Whether a source reports a vulnerability as used in known ransomware
# campaigns. Three-state so "source says no" (UNKNOWN) and "source is
# silent" (UNSPECIFIED) stay distinct.
enum KevRansomwareStatus {
	KNOWN
	UNKNOWN
	UNSPECIFIED
}

# A named ransomware campaign (with optional reference URL). Empty for CISA,
# which supplies no campaign names; populated by richer sources.
type KevRansomwareCampaign {
	name: String!
	url: String
}

# KEV detail for one CVE: the aggregated ransomware status plus every
# source's assertion (active and revoked).
type KevRecordDetails {
	cveId: String!
	ransomwareStatus: KevRansomwareStatus
	assertions: [KevSourceAssertion!]!
}

# One source's assertion that a CVE is known-exploited. revokedDate set means
# the source withdrew the listing -- the CVE still counts as KEV, the date is
# shown as a note. Date fields stay feed-format strings (yyyy-MM-dd).
type KevSourceAssertion {
	source: String!
	revokedDate: String
	vendorProject: String
	product: String
	vulnerabilityName: String
	dateAdded: String
	shortDescription: String
	requiredAction: String
	dueDate: String
	ransomwareStatus: KevRansomwareStatus
	ransomwareCampaigns: [KevRansomwareCampaign!]
	notes: String
	cwes: [String!]
}

type ViolationWithAttribution {
	# Opaque handle to page this finding's full attribution via findingAttributionByDate.
	findingKey: String!
	type: String
	purl: String!
	# Preview-capped lists + true totals (see VulnerabilityWithAttribution).
	resolvedIn: [ComponentAttribution!]!
	appearedIn: [ComponentAttribution!]!
	presentIn: [ComponentAttribution!]!
	resolvedInCount: Int!
	appearedInCount: Int!
	presentInCount: Int!
	isNetResolved: Boolean!
	isNetAppeared: Boolean!
	isStillPresent: Boolean!
	orgContext: OrgLevelContext
	analysisState: AnalysisState
}

type WeaknessWithAttribution {
	# Opaque handle to page this finding's full attribution via findingAttributionByDate.
	findingKey: String!
	cweId: String!
	severity: String
	ruleId: String
	location: String!
	# Preview-capped lists + true totals (see VulnerabilityWithAttribution).
	resolvedIn: [ComponentAttribution!]!
	appearedIn: [ComponentAttribution!]!
	presentIn: [ComponentAttribution!]!
	resolvedInCount: Int!
	appearedInCount: Int!
	presentInCount: Int!
	isNetResolved: Boolean!
	isNetAppeared: Boolean!
	isStillPresent: Boolean!
	orgContext: OrgLevelContext
	analysisState: AnalysisState
}

type OrgLevelContext {
	isNewToOrganization: Boolean!
	wasPreviouslyReported: Boolean!
	isPartiallyResolved: Boolean!
	isFullyResolved: Boolean!
	isInheritedInAllComponents: Boolean!
	componentCount: Int!
	affectedComponentNames: [String!]!
	# "Worsened" annotations from the posture-diff rollup (board task #38, phase 3). Tri-state:
	# null = not computed (legacy pairwise-diff path); true/false = computed from in-window
	# finding_change_events on the posture-diff path. previousSeverity is null unless
	# isSeverityIncreased is true.
	isNewlyKev: Boolean
	isSeverityIncreased: Boolean
	previousSeverity: String
}

type FindingChangesWithAttribution {
	vulnerabilities: [VulnerabilityWithAttribution!]!
	violations: [ViolationWithAttribution!]!
	weaknesses: [WeaknessWithAttribution!]!
	totalAppeared: Int!
	totalResolved: Int!
	# "Worsened" rollup counts (board task #38, phase 3 posture-diff). 0 on the legacy path.
	totalNewlyKev: Int
	totalSeverityIncreased: Int
	# Non-null when the window `from` predates the org's finding-change-event retention horizon: the
	# from-baseline could not be fully reconstructed, so buckets degrade to comparing against current
	# metrics for postures before this instant. Null when the window is fully within retention / legacy path.
	reconstructionClampedSince: DateTime
	# true = posture-endpoint diff semantics (window-endpoint reconstruction); false/absent = legacy
	# pairwise-across-releases semantics (e.g. an org whose event-log backfill has not yet certified).
	# Lets a client tell WHICH semantics it renders, since both share this payload at org scope.
	postureDiffApplied: Boolean
}

type ArtifactWithAttribution {
	purl: String!
	name: String
	version: String!
	# Preview-capped lists + true totals (see VulnerabilityWithAttribution).
	addedIn: [ComponentAttribution!]!
	removedIn: [ComponentAttribution!]!
	addedInCount: Int!
	removedInCount: Int!
	isNetAdded: Boolean!
	isNetRemoved: Boolean!
}

type SbomChangesWithAttribution {
	artifacts: [ArtifactWithAttribution!]!
	totalAdded: Int!
	totalRemoved: Int!
}



type VcsRepository {
	uuid: ID
	name: String
	org: ID
	uri: String
	type: String
	createdType: ProgrammaticType
	lastUpdatedBy: ID
	createdDate: DateTime
	"""
	Pull-request-level output triggers for this VCS repository. Currently
	constrained to ≤1 entry of type EXTERNAL_VALIDATION -- used by the PR
	aggregator to dispatch the aggregated check-run verdict to the SCM.
	"""
	outputTriggers: [ReleaseOutputEvent]
	"""
	Resolved PR-validation trigger for this repo. Per-repo
	{@code outputTriggers} always wins; otherwise the org-wide rule
	list is walked in order and the first match's trigger is returned.
	{@code source} discriminates between the two; {@code ruleName} is
	set only when source = ORG_RULE; {@code alsoMatchedRuleNames}
	carries any later-list rules whose pattern also matched (for the
	provenance UI's "rules X, Y also match; X wins" warning);
	{@code staleRuleNames} flags rules that matched but reference a
	missing/archived integration and were therefore skipped.
	"""
	effectivePrValidationTrigger: EffectivePrValidationTrigger
}

"""
Resolved PR-validation trigger snapshot for a VCS repository. See
{@link VcsRepository.effectivePrValidationTrigger}.
"""
type EffectivePrValidationTrigger {
	source: PrValidationTriggerSource
	trigger: ReleaseOutputEvent
	ruleName: String
	alsoMatchedRuleNames: [String]
	staleRuleNames: [String]
}

enum PrValidationTriggerSource {
	"""Per-repo trigger configured directly on this VCS row."""
	PER_VCS
	"""Inherited from an org-wide GlobalPrValidationTriggerRule."""
	ORG_RULE
	"""Neither per-repo nor any matching org rule -- no verdict will be dispatched."""
	NONE
}

"""
First-class PullRequest entity. Owns its own identity at the SCM level
(target VCS + identity string), its own commit list (SCE UUIDs), and
both inbound (release_validation_events) and outbound
(pr_validation_events) event streams.
"""
type PullRequest {
	uuid: ID
	org: ID
	targetVcsRepository: ID
	sourceVcsRepository: ID
	identity: String
	state: String
	title: String
	sourceBranchName: String
	targetBranchName: String
	endpoint: String
	commits: [ID]
	prCreatedDate: DateTime
	closedDate: DateTime
	mergedDate: DateTime
	createdDate: DateTime
	prValidationEvents: [PullRequestValidationEvent]
	releaseValidationEvents: [ReleaseValidationEvent]
	"""
	Releases currently attributed to this PR -- every release whose
	primary sourceCodeEntry is one of the PR's commits, scoped to
	the PR's org. Same logic the aggregator uses to compute the
	PR-level verdict (no dispatch is triggered). Empty when the PR
	has no commits or no releases have been minted against any of
	them yet.
	"""
	attributedReleases: [Release]
	"""
	Hydrated commit list -- SCE rows for every entry in `commits`.
	Order matches `commits` (head is the last element). Used by the
	UI to render the actual git commit SHA / message / author
	instead of just the SCE UUID. Missing SCEs (e.g. one that was
	since archived) are silently dropped.
	"""
	commitDetails: [SourceCodeEntry]
	"""
	Releases referenced by any release_validation_event in this PR's
	history -- superset of attributedReleases. Required so the UI can
	display release names for events whose release has since been
	superseded (newest-per-component attribution drops the older
	release from attributedReleases but its event row remains).
	Distinct on UUID; missing releases (archived) are silently dropped.
	"""
	validatedReleaseDetails: [Release]
	"""
	Latest pr_validation_event verdict whose sourceCodeEntry matches
	the PR's current head commit. Mirrors the aggregator's
	"latest-for-head" lookup so this resolver and the SCM dispatch
	read the same value. {@code null} when the PR has no commits, no
	validation events, or no event for the current head -- UI should
	render that as "pending / not yet validated".
	"""
	currentValidationState: ValidationState
	"""
	Distinct ROOT agents that contributed to this PR -- walks
	`commits → SCE.agent → resolveRoot`. One PR can be attributed to
	multiple agents (different commits from different sessions / keys).
	Empty when no commits carry agentic attribution. Order is by first
	appearance in `commits`.
	"""
	agents: [Agent]
}

type PullRequestValidationEvent {
	date: DateTime
	validationState: ValidationState
	comment: String
	sourceCodeEntry: ID
	attributedReleases: [ID]
}

type ReleaseValidationEvent {
	release: ID
	date: DateTime
	validationResult: ValidationState
}

enum ValidationState {
	SUCCESS
	FAILURE
	NEUTRAL
	SKIPPED
	CANCELLED
	"""
	Internal "verdict not yet computable" state -- recorded on
	pr_validation_events when at least one release attributed to the
	PR has no validation event yet. Never dispatched to the SCM
	(GitHub doesn't have a matching check-run conclusion); the prior
	terminal verdict's check-run stays in place until a new terminal
	verdict supersedes it.
	"""
	PENDING
}

type Branch {
	uuid: ID
	name: String
	component: ID
	componentDetails: Component
	components: [ID]
	status: Status
	type: BranchType
	vcs: ID
	vcsBranch: String
	dependencies: [ChildComponent]
	dependencyPatterns: [DependencyPattern]
	effectiveDependencies: [EffectiveDependency]
	org: ID
	versionSchema: String
	marketingVersionSchema: String
	versionType: VersionType
	metadata: String
	hasChildren: Boolean
	createdType: ProgrammaticType
	lastUpdatedBy: ID
	createdDate: DateTime
	autoIntegrate: AutoIntegrateState
	vcsRepositoryDetails: VcsRepository
	findingAnalyticsParticipation: FindingAnalyticsParticipation
}

