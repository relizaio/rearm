	responses: [AnalysisResponse!]
	recommendation: String
	workaround: String
}

# Single dependency-branch override for the versionFeatureSet
# mutation. The component to override is identified by either its
# UUID (componentUuid) OR by (vcsUri, repoPath) -- the latter resolves
# through the same component-by-VCS lookup used elsewhere in the
# CLI / programmatic flows. branch is the name of the branch on the
# resolved component to which the dependency should be re-pointed.
input VersionFeatureSetOverride {
	componentUuid: ID
	vcsUri: String
	repoPath: String
	branch: String!
}

input UpdateVulnAnalysisInput {
	analysisUuid: ID!
	state: AnalysisState!
	justification: AnalysisJustification
	details: String
	findingAliases: [String]
	severity: VulnerabilitySeverity
	responses: [AnalysisResponse!]
	recommendation: String
	workaround: String
}

enum LocationType {
	PURL
	CODE_POINT
}

enum FindingType {
	VULNERABILITY
	VIOLATION
	WEAKNESS
}

enum AnalysisScope {
	ORG
	RESOURCE_GROUP
	COMPONENT
	BRANCH
	RELEASE
}

enum AnalysisJustification {
	CODE_NOT_PRESENT
	CODE_NOT_REACHABLE
	REQUIRES_CONFIGURATION
	REQUIRES_DEPENDENCY
	REQUIRES_ENVIRONMENT
	PROTECTED_BY_COMPILER
	PROTECTED_AT_RUNTIME
	PROTECTED_AT_PERIMETER
	PROTECTED_BY_MITIGATING_CONTROL
}

# Artifact Collections
type AcollectionData {
	uuid: ID
	release: ID
	org: ID
	version: Long
	updateReason: CollectionUpdateReasonType
	artifactComparison: ArtifactComparison
	artifacts: [VersionedArtifact]
	createdDate: DateTime
	updatedDate: DateTime
	whoUpdated: WhoUpdated
}

type VersionedArtifact {
	artifactUuid: ID
	version: Long
	type: ArtifactType
	artifactDetails: Artifact
}

enum CollectionUpdateReasonType {
	INITIAL_RELEASE
	VEX_UPDATED
	ARTIFACT_UPDATED
	ARTIFACT_ADDED
	ARTIFACT_REMOVED
}

# Canonical SBOM component identity shared across releases. canonicalPurl is
# the purl with qualifiers and subpath stripped; name / group / version /
# type are cached from the purl for quick display and filtering. isRoot is
# true when at least one uploaded BOM had this component as its
# metadata.component (the "subject" of the BOM).
type SbomComponent {
	uuid: ID!
	canonicalPurl: String!
	type: String
	group: String
	name: String
	version: String
	isRoot: Boolean
}

# One row per (release, canonical component). artifactParticipations lists
# every artifact inside this release whose BOM referenced the component,
# together with the exact (qualifier-carrying) purls that artifact used.
# Edges are persisted as in-edges (parents) for fast impact-analysis lookups;
# dependedOnBy is therefore a direct read of the persisted parents column,
# while dependencies is reconstructed in memory by inverting parents across
# all rows of the same release. Each forward edge records the resolved
# target plus per-artifact declarations (preserving exact source/target
# purls).
type ReleaseSbomComponent {
	uuid: ID!
	releaseUuid: ID!
	sbomComponentUuid: ID!
	component: SbomComponent
	artifactParticipations: [SbomArtifactParticipation]
	dependencies: [ReleaseSbomDependency]
	dependedOnBy: [ReleaseSbomComponent]
	# Transitive `dependedOnBy` closure (deduped, BFS order) for this component
	# within the release. Use to render multi-hop "upstream paths to root":
	# each ancestor's own `dependedOnBy` resolves against the same per-request
	# graph context, so the UI can walk one hop at a time over this bounded
	# subgraph instead of re-fetching the entire release. Computed in memory
	# from the same context that drives `dependencies` / `dependedOnBy`, so
	# selecting it adds no DB work -- but it is per-row, so do not select on
	# every row of a release-wide list.
	ancestors: [ReleaseSbomComponent]
	createdDate: DateTime
	lastUpdatedDate: DateTime
}

type SbomArtifactParticipation {
	artifact: ID!
	exactPurls: [String]
}

type ReleaseSbomDependency {
	targetSbomComponentUuid: ID!
	targetCanonicalPurl: String!
	relationshipType: String!
	target: ReleaseSbomComponent
	declaringArtifacts: [SbomDependencyDeclaration]
}

type SbomDependencyDeclaration {
	artifact: ID!
	sourceExactPurl: String!
	targetExactPurl: String!
}

type DownloadLog {
	uuid: ID
	org: ID
	downloadType: DownloadType
	subjectType: DownloadSubjectType
	subjectUuid: ID
	subjectName: String
	downloadedBy: ID
	downloadedByName: String
	createdType: ProgrammaticType
