	# AI Agents
	# Refine display fields on an existing Agent (name, icon, color,
	# notes, status). Only non-null fields are applied -- partial edits
	# can't blank unrelated fields. Hierarchy fields and the model
	# ontology pointer are immutable from this entry point; sub-agent
	# registration goes through spawnSubAgentProgrammatic.
	updateAgent(input: AgentUpdateInput!): Agent

	# Set the admin-chosen display label for an agent. Org-admin only.
	# Does NOT touch the registration `name` (the runtime resolution
	# key) -- pass null/blank to clear and fall back to name.
	setAgentDisplayName(uuid: ID!, displayName: String): Agent

	# Open a session for a ROOT agent on the calling FREEFORM key. v1
	# requires agentName + agentModel on the input -- multi-root-per-key
	# means we cannot infer which agent the caller is acting as without
	# an explicit name, and the model identity is the primary
	# monitoring grouping so we ask for it up-front.
	#
	# Idempotent on (org, agent, clientSessionId): calling with the
	# same client session id while an OPEN session exists returns
	# that session (typical agent crash-recovery shape).
	sessionInitializeProgrammatic(sessionInit: SessionInitializeInput!): Session

	# Heartbeat -- bumps lastActivityAt. No-op on a CLOSED session.
	sessionTouchProgrammatic(sessionUuid: ID!): Session

	# Close the session. Terminal -- a closed session cannot be
	# re-opened. Idempotent on already-closed sessions.
	sessionCloseProgrammatic(sessionUuid: ID!): Session

	# Upload one or more artifacts and bind them to the session in a
	# single round-trip. Artifacts created via this path are owned by
	# the session (belongsTo=AGENT_SESSION) -- they don't dangle off
	# any release or component. This is the only way to add artifacts
	# to a session; attaching a pre-existing release / sce artifact
	# uuid is intentionally not exposed (artifacts that originate
	# elsewhere don't belong on a session).
	#
	# Multipart-encoded: each ArtifactInput.file is a separate part of
	# the multipart body per the Apollo upload spec.
	sessionAddArtifactProgrammatic(addArtifact: SessionAddArtifactInput!): Session

	# Refine title / branch / clientSessionId mid-session.
	sessionUpdateMetaProgrammatic(updateMeta: SessionUpdateMetaInput!): Session

	# Register a SUB agent under an existing parent agent (ROOT or SUB).
	# The new sub's rootAgent is resolved to the parent's owning root,
	# its model ontology defaults to the parent's, and its uuid is
	# appended to the parent's subAgents list. Inherits parent's API
	# keys for v1.
	spawnSubAgentProgrammatic(spawnSubAgent: SpawnSubAgentInput!): Agent

	# Refine ModelOntology display fields (publisher, description,
	# purl, notes). Name + version are immutable identity -- re-register
	# under a new name+version pair if needed.
	updateModelOntology(input: ModelOntologyUpdateInput!): ModelOntology

	# Attach (or replace) a CycloneDX ML-BOM model card on an existing
	# ontology row. The card is stored opaquely -- ReARM does not
	# validate its structure beyond JSON parsing.
	setModelOntologyModelCardProgrammatic(input: SetModelCardInput!): ModelOntology

	# AI-Agent policies (SAAS-only).
	#
	# Create or update an Agent policy. CEL is validated at write time
	# -- an invalid expression throws so a typo never silently no-ops
	# at evaluation. Use the same input to update (pass uuid).
	upsertAgentPolicy(input: AgentPolicyInput!): AgentPolicy

	# Toggle a policy's enabled flag without rewriting the rest.
	setAgentPolicyEnabled(uuid: ID!, enabled: Boolean!): AgentPolicy

	# Delete a policy (org admin only). Past verdicts on sessions keep
	# their recorded policy uuid for forensic value.
	deleteAgentPolicy(uuid: ID!): Boolean

	# Distribution module (SAAS-only): client + site CRUD. Pass uuid to
	# update. Deleting a client cascades to its sites (no DB FK).
	upsertClient(input: ClientInput!): Client
	"""Soft delete: archives the client, cascading to sites, shipments, and devices."""
	deleteClient(uuid: ID!): Boolean
	upsertSite(input: SiteInput!): Site
	"""Soft delete: archives the site, cascading to shipments and devices."""
	deleteSite(uuid: ID!): Boolean

	# Distribution module (SAAS-only): shipments (batch). shipProduct is
	# append-only (always a new row).
	shipProduct(input: ShipProductInput!): ShippedProduct
	"""Admin edit of an existing shipment (same input shape as shipProduct)."""
	updateShippedProduct(uuid: ID!, input: ShipProductInput!): ShippedProduct
	"""Soft delete: archives the shipment, cascading to its devices."""
	deleteShippedProduct(uuid: ID!): Boolean

	# Per-device layer. Phone-home (actual) and 821 disposition (tracking) are
	# per-device. updateDevicePlan records a field-repair / version change.
	upsertDevice(input: DeviceInput!): Device
	reportDeviceActual(uuid: ID!, input: ActualReportInput!): Device
	updateDeviceTracking(uuid: ID!, input: TrackingInput!): Device
	updateDevicePlan(uuid: ID!, expectedRelease: ID): Device
	"""Soft delete: archives the device."""
	deleteDevice(uuid: ID!): Boolean

	# Digital twin. addDeviceEvent records a field event (failure / repair /
	# replacement / inspection) anchored to the release ontology (hbomRef / purl).
	# reportDeviceState is the programmatic (API-key) phone-home: submit observed
	# digests (or a raw k8s image list) and reconcile against the expected release.
	addDeviceEvent(input: DeviceEventInput!): DeviceEvent
	"""Soft delete: archives the event."""
	deleteDeviceEvent(uuid: ID!): Boolean
	reportDeviceState(report: DeviceStateReportInput!): Device
	"""Operator-posted observed-state report (same payload as reportDeviceState, JWT auth)."""
	reportDeviceStateManual(report: DeviceStateReportInput!): Device

	# Rebuild a hardware release HBOM components from its BOM artifact.
	reconcileReleaseHbomComponents(releaseUuid: ID!): Boolean

	# Committer + signing-key management.
	upsertCommitter(input: CommitterInput!): Committer
	archiveCommitter(uuid: ID!): Committer
	enrollSigningKey(input: SigningKeyInput!): SigningKey

	# FREEFORM-auth'd self-enrollment for an AI agent. The calling key
	# must have PermissionFunction.AGENT at ORGANIZATION scope and the
	# signing-key input's {@code ownerType} must be {@code AGENT} with
	# {@code ownerUuid} = the root agent resolved from the key. The
	# operator-driven {@code enrollSigningKey} is the equivalent for
	# COMMITTER + AGENT owners with a JWT -- this variant lets an agent
	# bootstrap its own signing key on first run without needing the
	# operator to do it ahead of time.
	enrollSigningKeyProgrammatic(signingKey: AgentSigningKeyInput!): SigningKey
	revokeSigningKey(uuid: ID!): SigningKey
	"""
	Update the allowed_signers principal (identity) on an enrolled key.
	Operator JWT path. Fingerprint / pubKey are immutable; SSH keys
	must keep a non-blank identity. Pass null/blank to clear a GPG
	informational identity.
	"""
	updateSigningKeyIdentity(uuid: ID!, identity: String): SigningKey

	# Notifications framework -- synthetic event injection (Phase 2d).
	#
	# Write a curated synthetic event into the org's outbox so the rest
	# of the pipeline (fan-out, channel dispatch, history) can be
	# exercised end-to-end without waiting for a real CVE / VEX change.
	# Operator-only -- gated as ADMIN at ORGANIZATION scope. Returns the
	# persisted outbox event for the caller to link to the resulting
	# history rows (which land asynchronously on the next fan-out tick).
	injectSyntheticEvent(orgUuid: ID!, template: SyntheticEventTemplateEnum!): NotificationOutboxEventResult!

	# Notifications framework -- channel test (Phase 2d).
	#
	# Inject a synthetic event tagged with the given channel as the
	# direct test target. The fan-out worker skips subscription / CEL /
	# severity-gate evaluation and writes a single delivery row addressed
	# at this channel; the channel worker then dispatches the rendered
	# payload to the real webhook. Used by the "Test channel" button to
	# confirm a webhook is reachable + auth'd before relying on real
	# event traffic. Org-admin only; the channel must belong to the
	# caller's org.
	testNotificationChannel(channelUuid: ID!): NotificationOutboxEventResult!

	# Notifications framework -- channel CRUD (Phase 3).
	#
	# Upsert is one mutation per the rearm convention (see
	# upsertAgentPolicy, upsertCommitter). uuid null on the input = create;
	# uuid present = update. webhookUrl null/blank on update preserves
	# the existing encrypted value (rename without re-typing the URL).
	# Slack URL prefix is enforced server-side at save time.
	upsertNotificationChannel(input: NotificationChannelInput!): NotificationChannelResult!

	# Status flip (ENABLED / DISABLED). Free-form transitions; the
	# fan-out + dispatch workers already short-circuit on DISABLED so
	# this is the kill-switch surface. No-op when status already matches.
	setNotificationChannelStatus(uuid: ID!, status: NotificationChannelStatusEnum!): NotificationChannelResult!

	# Hard delete. In-flight deliveries pointing at this channel get
	# marked FAILED by the delivery worker (channel-no-longer-exists path).
	# Soft-delete semantics are available via setNotificationChannelStatus(DISABLED).
	deleteNotificationChannel(uuid: ID!): Boolean!

	# Notifications framework -- channel-group CRUD (Phase 13b).
	#
	# A channel group is a named, cross-type bundle of channels
	# ("security-oncall" = Slack #sec + Teams #leadership + Email
	# security@) referenceable from a subscription route. At fan-out
	# the route's channelGroups list is resolved to member channel
	# UUIDs and merged with the route's direct channels (dedup,
	# first-seen order preserved). Each member channel still produces
	# its own delivery row with independent retry / dedup / audit --
	# the group is purely a naming layer.
	#
	# Upsert: uuid null = create; uuid present = update. Service-layer
	# validation rejects empty channel lists, duplicate channel UUIDs,
	# missing channel UUIDs, and cross-org channel membership.
	# Cross-org reparent on update is also rejected.
	upsertNotificationChannelGroup(input: NotificationChannelGroupInput!): NotificationChannelGroupResult!

	# Hard delete. Subscriptions that referenced this group keep their
	# reference UUID; the fan-out treats a missing group as "no members"
	# and silently no-ops the group from the route's resolution. No
	# cascade -- operators may want to recreate a group with the same
	# name and have existing references stay broken until manually
	# repointed.
	deleteNotificationChannelGroup(uuid: ID!): Boolean!

	# Notifications framework -- subscription CRUD (Phase 3).
	#
	# Upsert: uuid null = create, present = update. Service-layer
	# validation enforces: CEL filter compiles + meets the safety caps,
	# every route channel uuid exists in the same org, record_data
	# stays under the 256 KB JSONB cap.
	upsertNotificationSubscription(input: NotificationSubscriptionInput!): NotificationSubscriptionResult!

	# Status flip (ACTIVE / DISABLED / PREVIEW). PREVIEW is the
	# observe-only mode used during Quick Start verification; the
	# fan-out worker's active-subscription query treats it like
	# DISABLED for live traffic. No-op when status already matches.
	setNotificationSubscriptionStatus(uuid: ID!, status: NotificationSubscriptionStatusEnum!): NotificationSubscriptionResult!

	# Hard delete. Customers wanting reversible pause flip status to
	# DISABLED instead.
	deleteNotificationSubscription(uuid: ID!): Boolean!

	# Notifications framework -- Inbox MVP read-state (Phase 14).
	#
	# markNotificationRead: idempotent. A repeat call on the same
	# (caller × delivery) is a no-op upsert; read_at anchors to the
	# FIRST read so the inbox can show "you saw this 3 days ago"
	# without drifting on every re-render. Authorization: the caller
	# must be able to see this delivery under the inbox visibility
	# filter (org-admin tier OR perspective-member with intersecting
	# perspectives) -- toggling read-state of a delivery you can't see
	# is rejected, not silently succeeded.
	markNotificationRead(deliveryUuid: ID!): NotificationInboxItem!

	# markNotificationUnread: returns true when an existing read row
	# was removed, false when the (caller × delivery) pair was already
	# unread. Same visibility auth as markNotificationRead.
	markNotificationUnread(deliveryUuid: ID!): Boolean!

	# Mark every currently-visible-and-unread delivery in the org as
	# read for the caller. Returns the count of newly-created read
	# rows AND a hasMore flag -- the backend caps a single sweep at
	# 500 to bound the per-call work; the UI uses hasMore to decide
	# whether to surface "re-run to clear the remaining" guidance.
	# Bulk variant of markNotificationRead; same visibility scope
	# (org-admin or perspective-member).
	#
	# Note: ignores notificationInbox's status / eventType / unreadOnly
	# filters by design -- "Mark all as read" is the user-facing
	# kill-switch for the whole inbox-tab badge, not a scoped sweep.
	# A future "Mark filtered as read" would land as a separate
	# mutation that takes the same filter inputs as notificationInbox.
	markAllNotificationsRead(orgUuid: ID!): MarkAllNotificationsReadResult!
}

# Curated synthetic event templates surfaced through the
# injectSyntheticEvent mutation. The full set lives on
# {@code SyntheticEventTemplates.Template}; each value here maps 1:1
# to a constant in that enum.
enum SyntheticEventTemplateEnum {
	CRITICAL_VULN_SINGLE_SHIPPED_RELEASE
	CRITICAL_KEV_VULN_THREE_RELEASES_IN_PAYLOAD
	KEV_LISTED_DRAFT_RELEASE
	SEVERITY_BUMP_MEDIUM_TO_CRITICAL
	KEV_ADDED
	VEX_RESOLVED_NOT_AFFECTED
}

# Returned by injectSyntheticEvent + testNotificationChannel + the
# notificationOutboxEvent read query. The UI polls
# notificationDeliveries(eventUuid: ...) keyed by uuid to show the
# rendered output.
type NotificationOutboxEventResult {
	uuid: ID!
	org: ID!
	eventType: String!
	status: String!
	occurredAt: String!
	origin: String!
	dedupKey: String
	# Non-null only for testNotificationChannel -- the target channel.
	channelTestTarget: ID
}

# Lifecycle status of a single delivery row. Promoted to a typed
# GraphQL enum (Phase 2e layer-2) so filter args + output projections
# share one declaration and a typo in either direction is rejected at
# the parser instead of silently returning zero rows.
enum NotificationDeliveryStatusEnum {
	PENDING
	SENT
	FAILED
	ACKED
	# Rate limit hit at fan-out time -- delivery row persisted for
	# history but never dispatched.
	RATE_LIMITED
	# CEL evaluation aborted on the wall-clock budget; subscription
	# circuit-breaker may auto-disable.
	EVAL_TIMEOUT
	# Customer-initiated channel test from the "send test event" UI button.
	TEST
	# Subscription is in PREVIEW mode; render captured for history,
	# never dispatched.
	PREVIEW
	# Held in an EMAIL channel's rolling-cap digest window; flushed as
	# one digest email when the window expires.
	BATCHED
}

# Whether the delivery's originating outbox event was REAL traffic or
# a SYNTHETIC injection (channel test / Quick Start verify / harness).
enum NotificationDeliveryOriginEnum {
	REAL
	SYNTHETIC
}

# One delivery row -- the result of fan-out picking a channel for an
# event. Carries queue state (status, attemptCount, nextAttemptAt) for
# the operator UI's "what's happening with my notifications" view.
# subscriptionUuid is nullable for Phase 2d channel-test rows;
# channelUuid is nullable for per-user targeted rows (approval-request
# events), which bypass channel routing entirely.
# nextAttemptAt is nullable to match the projector's null defense --
# the DB column is non-null in practice, but the schema declaration
# stays permissive so a hypothetical future row with a null value
# wouldn't blow up the GraphQL layer.
type NotificationDeliveryResult {
	uuid: ID!
	org: ID!
	outboxEventUuid: ID!
	subscriptionUuid: ID
	channelUuid: ID
	status: NotificationDeliveryStatusEnum!
	origin: NotificationDeliveryOriginEnum!
	dedupKey: String
	attemptCount: Int!
	nextAttemptAt: String
	sentAt: String
	lastError: String
	createdDate: String!
}

type NotificationDeliveriesPage {
	items: [NotificationDeliveryResult!]!
	totalCount: Int!
	limit: Int!
	offset: Int!
}

# Phase 14 Inbox MVP item. Sibling to NotificationDeliveryResult -- same
# core delivery fields (uuid, status, attemptCount, etc.) plus the
# per-caller read-state (readAt is null when unread for this user).
# Maintained as a separate type rather than extending
# NotificationDeliveryResult so the History view's projection
# stays clean (History is org-scoped audit, not per-user).
type NotificationInboxItem {
	uuid: ID!
	org: ID!
	outboxEventUuid: ID!
	subscriptionUuid: ID
	# Nullable: per-user targeted rows (approval requests) have no channel.
	channelUuid: ID
	# Server-resolved display name of the channel addressed by channelUuid.
	# Carried here so the non-admin notification bell never has to call the
	# admin-only channel-list query to label a row. Null when the channel
	# has been deleted (channelUuid no longer resolves to an Integration).
	channelName: String
	# Whether the addressed channel is currently enabled. Null when the row is
	# channel-less (targeted) or the channel was deleted. False means deliveries
	# to it are paused -- lets the inbox distinguish a disabled channel from a
	# deleted one instead of dead-ending at "(deleted channel)".
	channelEnabled: Boolean
	# Operator-facing reason a channel was auto-disabled (e.g. a bad webhook
	# URL); null when the channel is enabled, manually disabled, deleted, or
	# channel-less. Surfaced so a failed delivery explains itself.
	channelDisabledReason: String
	status: NotificationDeliveryStatusEnum!
	origin: NotificationDeliveryOriginEnum!
	dedupKey: String
	attemptCount: Int!
	nextAttemptAt: String
	sentAt: String
	lastError: String
	createdDate: String!
	# Null = unread for the calling user; non-null = ISO-8601 timestamp
	# of when the caller first marked this delivery read. Subsequent
	# re-reads are idempotent and do NOT advance this anchor -- the
	# inbox MVP needs a stable "first seen" cue.
	readAt: String
	# Event-type label from the originating outbox event. Lifted so the
	# inbox row can render the event kind without a separate lookup.
	eventType: NotificationEventTypeEnum
	# Severity rolled up from the outbox event payload. NONE when the
	# event type doesn't carry a severity (e.g. some VEX state changes).
	severity: NotificationSeverityEnum
	# Canonical human-rendered inbox text built server-side by
	# NotificationInboxFormatter. Mirrors what a user would see at the
	# top of their Slack / email notification but stays channel-agnostic.
	# Either can be null when the event payload is malformed; the UI
	# falls back to {eventType, severity} for a label-only row.
	title: String
	description: String
	# The originating outbox event's recordData serialized as a JSON
	# string. Lets the UI deep-link into the affected release /
	# vulnerability without an extra round-trip. UI parses on demand --
	# the schema doesn't enumerate per-event-type fields here so a new
	# event type doesn't break the inbox query.
	payloadJson: String
}

type NotificationInboxPage {
	items: [NotificationInboxItem!]!
	totalCount: Int!
	# Subset of totalCount that is currently unread for the caller --
	# convenient for the inbox-tab badge so the UI doesn't need a
	# separate notificationUnreadCount round-trip when it's already
	# rendering the page.
	unreadCount: Int!
	limit: Int!
	offset: Int!
}

# Phase 14 Inbox MVP -- markAllNotificationsRead result. See the
# mutation's javadoc for the cap rationale and the count/hasMore
# semantics.
type MarkAllNotificationsReadResult {
	count: Int!
	hasMore: Boolean!
}

# Subscription summary. Complex nested config (filter, routes, rateLimit)
# remains JSON-stringified through the read surface -- Phase 3 introduces
# typed *Input* shapes for writes, but the read side keeps the existing
# string projection to avoid expanding the schema with parallel inner
# types. A future phase can unify them.
type NotificationSubscriptionResult {
	uuid: ID!
	org: ID!
	resourceGroup: ID
	name: String!
	status: NotificationSubscriptionStatusEnum!
	eventTypes: [NotificationEventTypeEnum!]!
	# JSON-stringified filter config: { mode, presetConfig, celExpression }.
	filter: String
	# JSON-stringified route table:
	# [{ whenSeverityAtLeast, andEnvIn, andLifecycleIn, channels, perspectives, channelGroups }].
	# perspectives is the Phase 12 list of UUIDs gating the route -- null/empty = no gate.
	# channelGroups is the Phase 13b list of group UUIDs expanded to member channels at fan-out.
	routes: String
	dedupWindowMinutes: Int
	# JSON-stringified rate limit config: { maxPerWindow, windowMinutes }. Nullable.
	rateLimit: String
	# Hibernate @Version-managed row revision. The UI captures this on
	# Edit load and round-trips it as expectedRevision on the next save
	# so a concurrent edit by another admin is rejected with a clear
	# "this record was edited by another user -- reload" error rather
	# than silently overwriting their changes.
	revision: Int!
}

# Channel summary. encryptedSecret is NEVER projected through this
# read surface -- webhook URLs / SMTP passwords are set-only.
#
# configData is intentionally omitted in Phase 2e. The blob can carry
# Slack/Teams webhook URLs (when the customer chose to store them as
# config rather than as the encrypted secret), and a webhook URL is
# itself an auth credential -- exposing it through an org-admin read
# would let any admin lift production-channel URLs and post arbitrary
# content. Phase 3 channel CRUD introduces typed input fields that
# split credential-vs-display; the read surface stays conservative.
type NotificationChannelResult {
	uuid: ID!
	org: ID!
	resourceGroup: ID
	name: String!
	type: NotificationChannelTypeEnum!
	status: NotificationChannelStatusEnum!
	# Row revision (bumped manually on each save -- the underlying
	# Integration row has no Hibernate @Version); round-tripped as
	# expectedRevision on the next save to reject concurrent admin
	# edits. See the NotificationSubscriptionResult.revision comment.
	revision: Int!
	# Effective email digest policy (EMAIL channels only; null for
	# other types). Defaults applied: absent config reads back as
	# ROLLING / PT24H. Not credentials -- safe on the read surface,
	# unlike configData (see type comment above).
	digestMode: NotificationEmailDigestModeEnum
	digestInterval: String
	# Recipient inbox addresses (EMAIL channels only; null for other
	# types). Display data, not credentials -- the edit UI needs the
	# current list to render. The configData embargo stays in force
	# for every other type.
	emailRecipients: [String!]
	# Operator-facing reason a channel was AUTO-disabled (e.g. its webhook
	# URL isn't the expected host). Null when enabled or manually disabled.
	# Lets the Catalog explain why a channel stopped delivering and prompt a
	# re-verify, instead of the failure only showing as FAILED History rows.
	disabledReason: String
}

# Channel-group summary (Phase 13b). Pure-naming layer -- no per-type
# config, no secrets, no status. {@code channels} is the ordered list
# of member channel UUIDs (each one points at a NotificationChannel
# in the same org; cross-org membership is rejected at save time).
# revision / createdDate / lastUpdatedDate ride along so the UI can
# show "last edited by whom, when" without a second round-trip.
type NotificationChannelGroupResult {
	uuid: ID!
	org: ID!
	resourceGroup: ID
	name: String!
	channels: [ID!]!
	revision: Int!
	createdDate: String
	lastUpdatedDate: String
}

# ---------------------------------------------------------------------
# Notifications framework -- enums (promoted from String in Phase 3).
# ---------------------------------------------------------------------

# Channel destination types. Slack only in v1; Teams / SMTP / Sentinel
# land in later phases.
enum NotificationChannelTypeEnum {
	SLACK
	# Generic webhook (Phase 4). Customer-defined HTTPS endpoint with
	# optional bearer-token or HMAC-SHA256 auth. Catches PagerDuty /
	# Opsgenie / Splunk / in-house receivers without per-vendor work.
	WEBHOOK
	# Email recipient list (Phase 9). SMTP / SendGrid creds come from
	# system config; per-channel state is just the recipient list.
	EMAIL
	# Microsoft Teams via Power Automate Workflows webhook (Phase 10).
	# Adaptive Card v1.5 envelope; webhook URL is the auth credential.
	MS_TEAMS
	# Azure Sentinel via the Logs Ingestion API + DCR (Phase 11).
	# Six-field SP-credential + DCR-routing secret; client-credentials
	# OAuth bearer.
	SENTINEL
}

# Authentication scheme for outbound WEBHOOK deliveries.
#   NONE          -- no auth header (URL secrecy + transport security only)
#   BEARER        -- Authorization: Bearer <token>
#   HMAC_SHA256   -- X-Reliza-Signature: sha256=<hex of HMAC over body>
enum WebhookAuthSchemeEnum {
	NONE
	BEARER
	HMAC_SHA256
}

# Channel lifecycle status. DISABLED short-circuits dispatch.
enum NotificationChannelStatusEnum {
	ENABLED
	DISABLED
}

# Subscription lifecycle status. PREVIEW is observe-only (used during
# Quick Start verification); the fan-out worker treats it as not-active
# for live traffic.
enum NotificationSubscriptionStatusEnum {
	ACTIVE
	DISABLED
	PREVIEW
}

# Domain event types that can trigger notifications.
enum NotificationEventTypeEnum {
	NEW_VULN_AFFECTS_RELEASES
	VULNERABILITY_RECORD_UPDATED
	VEX_STATE_CHANGED
	RELEASE_CREATED
	RELEASE_LIFECYCLE_CHANGED
	RELEASE_BOM_DIFF
	APPROVAL_REQUESTED
	APPROVAL_RESOLVED
}

# Vuln severity classification carried on event payloads + route gates.
enum NotificationSeverityEnum {
	CRITICAL
	HIGH
	MEDIUM
	LOW
	INFO
	NONE
}

# CEL evaluation mode for subscription filters.
enum NotificationEvaluationModeEnum {
	PRESET
	ADVANCED
}

# ---------------------------------------------------------------------
# Notifications framework -- write inputs (Phase 3).
# ---------------------------------------------------------------------

# Channel write input. uuid null = create; uuid present = update. The
# per-type secret config lives in a nested input matching the channel
# type -- customer supplies the one matching `type` and the service
# ignores the others. On update, leaving the matching config null
# preserves the existing encrypted value ("rename without re-typing").
input NotificationChannelInput {
	uuid: ID
	# Optimistic-locking gate. On update, the UI sends the revision
	# value it captured at Edit-load time; the service rejects the
	# save when the current DB row's revision is higher (a concurrent
	# admin edit landed between load and save). Null on create or for
	# callers opting out of the check.
	expectedRevision: Int
	org: ID!
	resourceGroup: ID
	name: String!
	type: NotificationChannelTypeEnum!
	status: NotificationChannelStatusEnum
	slackConfig: NotificationSlackChannelConfigInput
	webhookConfig: NotificationWebhookChannelConfigInput
	emailConfig: NotificationEmailChannelConfigInput
	teamsConfig: NotificationTeamsChannelConfigInput
	sentinelConfig: NotificationSentinelChannelConfigInput
}

# Azure Sentinel channel config (Phase 11). Six required fields:
# the three SP-credential fields (tenantId, clientId, clientSecret)
# acquire an Azure AD bearer token; the three DCR-routing fields
# (dcrEndpoint, dcrImmutableId, streamName) target the Logs Ingestion
# API. All six are serialized together as a SentinelChannelSecret blob
# and encrypted at rest. On update, leaving the SP-credential fields
# blank preserves the existing encrypted value.
input NotificationSentinelChannelConfigInput {
	tenantId: String
	clientId: String
	clientSecret: String
	dcrEndpoint: String
	dcrImmutableId: String
	streamName: String
}

# MS Teams channel config (Phase 10). The webhook URL is the auth
# credential -- same shape as Slack. Validated at save and dispatch
# against the Power Automate Workflows host suffixes (logic.azure.com
# for the LogicApps-style URL and powerplatform.com for the newer
# Power-Platform-environment URL Microsoft hands out).
input NotificationTeamsChannelConfigInput {
	webhookUrl: String
}

# Email-channel config (Phase 9; digest fields Phase 5). The "auth
# credential" for email is the system's SMTP / SendGrid setup on
# SystemInfoService; per-channel state is the recipient list plus the
# digest policy. Stored unencrypted in the channel's parameters
# (recipients aren't secret -- they're inbox addresses on customer
# infrastructure). Update semantics are per-field: null recipients
# preserves the existing list (digest-only update); null digest fields
# preserve the existing digest config. digestInterval is an ISO-8601
# duration (e.g. "PT24H"), accepted range PT5M..P7D. Absent digest
# config means rolling 24h digest (on by default); actionable events
# (approval requests / resolutions) always send immediately.
# Mid-window changes: switching digestMode to IMMEDIATE releases any
# already-batched rows for individual delivery right away; changing
# only digestInterval leaves the open batch's deadline as-is -- the
# new interval applies from the next window.
input NotificationEmailChannelConfigInput {
	recipients: [String!]
	digestMode: NotificationEmailDigestModeEnum
	digestInterval: String
}

# Email digest batching mode. ROLLING = at most one non-actionable
# email per digestInterval; overflow is held and flushed as a single
# digest email when the window expires. IMMEDIATE = no batching.
enum NotificationEmailDigestModeEnum {
	IMMEDIATE
	ROLLING
}

# Slack-specific channel config. Only the incoming-webhook URL -- the
# URL itself is the auth credential.
input NotificationSlackChannelConfigInput {
	webhookUrl: String
}

# Channel-group write input (Phase 13b). uuid null = create; uuid
# present = update. Every {@code channels} UUID must resolve to a
# channel in the same {@code org}; duplicate UUIDs within the list
# are rejected at save time. Empty {@code channels} list is also
# rejected -- a group with zero members would silently no-op every
# route that referenced it.
input NotificationChannelGroupInput {
	uuid: ID
	# Optimistic-locking gate. See NotificationChannelInput.expectedRevision.
	expectedRevision: Int
	org: ID!
	resourceGroup: ID
	name: String!
	channels: [ID!]!
}

# Generic webhook channel config (Phase 4). url is the customer
# endpoint (required, must be HTTPS). authScheme picks how the
# dispatcher signs each POST. authToken carries the bearer token or
# HMAC shared secret -- required when authScheme != NONE.
input NotificationWebhookChannelConfigInput {
	url: String
	authScheme: WebhookAuthSchemeEnum
	authToken: String
}

# Subscription write input. Mirrors the existing
# NotificationSubscriptionData record 1:1; nested config is typed
# rather than JSON-stringified because the write path needs schema-
# level validation.
input NotificationSubscriptionInput {
	uuid: ID
	# Optimistic-locking gate. See NotificationChannelInput.expectedRevision.
	expectedRevision: Int
	org: ID!
	resourceGroup: ID
	name: String!
	status: NotificationSubscriptionStatusEnum!
	eventTypes: [NotificationEventTypeEnum!]!
	filter: NotificationFilterInput
	routes: [NotificationRouteInput!]!
	dedupWindowMinutes: Int
	rateLimit: NotificationRateLimitInput
}

input NotificationFilterInput {
	mode: NotificationEvaluationModeEnum!
	# Free-form preset state surfaced as a JSON string so the UI can
	# evolve the preset toggles without a schema bump per field.
	presetConfigJson: String
	# CEL expression. Validated server-side via NotificationCelEvaluator.
	celExpression: String
}

input NotificationRouteInput {
	whenSeverityAtLeast: NotificationSeverityEnum
	andEnvIn: [String!]
	# Re-uses the existing release-lifecycle enum (declared elsewhere
	# in this schema) so a customer using the same lifecycle name in
	# a route as in a release stays consistent.
	andLifecycleIn: [ReleaseLifecycleEnum!]
	# Direct channel UUIDs the route delivers to. May be empty when
	# channelGroups is non-empty -- at least one of {channels, channelGroups}
	# must resolve to a non-empty merged list at fan-out time, otherwise
	# the route is logged + skipped.
	channels: [ID!]!
	# Phase 12 perspective scoping: limit this route's deliveries to
	# events that touch a release in at least one of these perspectives.
	# Empty / unset = no perspective gate (match anything). The route
	# enrichment populates AffectedRelease.perspectives from the
	# release's component, and the fan-out intersects against this list.
	#
	# Null vs. [] equivalence: DGS coerces a missing / explicit-null
	# field to Java `null`; an explicit `[]` becomes an empty List.
	# Both are treated as "no gate" by the gate logic
	# (perspectiveGateMatches in NotificationFanOutService), so callers
	# may pass either shape with identical effect.
	perspectives: [ID!]
	# Phase 13b channel-group expansion. UUIDs of NotificationChannelGroups
	# whose member channels are merged with the route's direct {@code channels}
	# list at fan-out time. Missing groups (deleted, never existed) are
	# silently skipped; dedup is first-seen across {channels ⨁ groups}.
	# Same null/[] equivalence as perspectives: both treated as "no group
	# expansion."
	channelGroups: [ID!]
}

input NotificationRateLimitInput {
	maxPerWindow: Int
	windowMinutes: Int
}

type EnrichmentTriggerResult {
	triggered: Boolean!
	message: String
	bomUuid: ID
}

enum BomMediaType {
    JSON
    CSV
    EXCEL
}

type Deliverable {
	uuid: ID
	name: String
	org: ID
	displayIdentifier: String
	branch: ID
	type: String
	notes: String
	tags: [TagRecord]
	version: String
	publisher: String
	group: String
	supportedOs: [OSEnum]
	supportedCpuArchitectures: [CPUArchitectureEnum]
	softwareMetadata: SoftwareMetadata
	hardwareMetadata: HardwareMetadata
	quantity: Int
	artifacts: [ID]
	artifactDetails: [Artifact]
	identifiers: [Identifier]
}

# ===== Distribution / HBOM -- CDX-aligned hardware deliverable metadata =====
enum PartyRole { MANUFACTURER ASSEMBLER SUPPLIER QUALITY_CONTROL DISTRIBUTOR OTHER }

type Coords { latitude: Float longitude: Float }
input CoordsInput { latitude: Float longitude: Float }
type Address { streetAddress: String city: String region: String postalCode: String country: String isoCode: String coords: Coords }
input AddressInput { streetAddress: String city: String region: String postalCode: String country: String isoCode: String coords: CoordsInput }
type PartyContact { name: String email: String phone: String }
input PartyContactInput { name: String email: String phone: String }
type OriginShare { originCode: String percentage: Float }
input OriginShareInput { originCode: String percentage: Float }
"""Country-of-origin + multi-source split (HBOM extension; emitted as a CDX property)."""
type Origin { basis: String origins: [OriginShare] }
input OriginInput { basis: String origins: [OriginShareInput] }
type ExternalRef { type: String url: String comment: String }
input ExternalRefInput { type: String url: String comment: String }
"""A CDX-2.0 party (entity with roles), per spec PR #930."""
type Party { roles: [PartyRole] bomRef: String priority: Int name: String address: Address contacts: [PartyContact] url: String origin: Origin }
input PartyInput { roles: [PartyRole] bomRef: String priority: Int name: String address: AddressInput contacts: [PartyContactInput] url: String origin: OriginInput }
"""CDX-aligned production facts for a hardware deliverable (a produced lot)."""
type HardwareMetadata { parties: [Party] origin: Origin manufactureDate: String externalRefs: [ExternalRef] extensions: Object }
input HardwareMetadataInput { parties: [PartyInput] origin: OriginInput manufactureDate: String externalRefs: [ExternalRefInput] extensions: Object }

type SoftwareMetadata {
	buildId: String
	buildUri: String
	cicdMeta: String
	digests: [String]
	digestRecords: [DigestRecord]
	dateFrom: DateTime
	dateTo: DateTime
	duration: Long
	packageType: PackageType
	downloadLinks: [Downloadlink]
}

type Component {
	uuid: ID
	name: String
	org: ID
	resourceGroup: ID
	type: ComponentType
	kind: ComponentKind
	versionSchema: String
	marketingVersionSchema: String
	versionType: VersionType
	vcs: ID
	vcsRepositoryDetails: VcsRepository
	featureBranchVersioning: String
	repositoryEnabled: Int
	status: Status
	apiKeyId: String
	apiKey: String
	createdType: ProgrammaticType
	lastUpdatedBy: ID
	createdDate: DateTime
	defaultConfig: String
	visibilitySetting: VisibilitySetting
	approvalPolicy: ID
	approvalPolicyDetails: ApprovalPolicy
	"""
	Resolved approval policy for this component. Per-component
	{@code approvalPolicy} wins when present AND still references an
	existing policy. Otherwise the org-wide rule list is walked in
	order; the first rule whose {@code namePattern} matches the
	component's name AND whose {@code componentType} accepts the
	component's type contributes its policy. {@code source} discriminates
	between the cases; {@code ruleName} is set only when source =
	ORG_RULE; {@code alsoMatchedRuleNames} carries any later-list rules
	whose pattern + type-filter also matched; {@code perComponentPolicyArchived}
	is true when the component carried a per-component reference but
	the referenced policy was archived/missing, so resolution fell
	through to org rules (signals a stale reference for the UI to
	warn about).
	"""
	effectiveApprovalPolicy: EffectiveApprovalPolicy
	releaseInputTriggers: [ReleaseInputEvent]
	outputTriggers: [ReleaseOutputEvent]
	identifiers: [Identifier]
	# Distribution module: device classification + profiles + native identifiers.
	nature: ComponentNature
	deviceClass: DeviceClass
	medicalProfile: MedicalProfile
	repoPath: String
	authentication: ComponentAuthentication
	branchSuffixMode: BranchSuffixMode
	globalInputEventRefs: [GlobalInputEventRef]
	perspectiveDetails: [Perspective]
	"""Component-level sid override (null = INHERIT)."""
	sidPurlOverride: SidPurlOverride
	"""Component-level decoded authority segments (null/empty = none stored)."""
	sidAuthoritySegments: [String!]
	"""Internal/external classification (D16). Null on legacy rows is treated as INTERNAL."""
	isInternal: BelongsToOrganization
	"""
	Synthetic component-level lifecycle derived from the lifecycles of the
	component's releases:
	- if every release lifecycle is ≤ GENERAL_AVAILABILITY, returns the
	  most-advanced of those (i.e. max-pre-or-at-GA);
	- otherwise returns the smallest lifecycle ≥ GENERAL_AVAILABILITY
	  observed across releases (i.e. min-post-GA).
	Null when the component has no releases.
	"""
	effectiveLifecycle: ReleaseLifecycleEnum
	"""Manually-assigned lead user UUIDs for this component/product."""
	leads: [ID!]
	"""Resolved org-user details for the manually-assigned leads."""
	leadDetails: [OrgUserData!]
	"""Freeform stakeholder contacts for non-registered users (HTML-sanitized on write)."""
	contacts: [ComponentContact!]
	"""
	Derived team: org users holding a READ_WRITE-or-stronger COMPONENT-scoped
	permission on this component. Falls back up the parent (product) chain when
	the component itself has no direct members.
	"""
	team: [OrgUserData!]
	"""
	Derived approvers: org users whose COMPONENT-scoped permission on this
	component carries one or more approval-role grants. Same parent fallback as team.
	"""
	approvers: [OrgUserData!]
}

"""A freeform stakeholder contact for someone who is not a registered ReARM user."""
type ComponentContact {
	name: String
	contact: String
}

enum ComponentKind {
	HELM
	GENERIC
}

type Identifier {
	idType: IdentifierType
	idValue: String
}

type BulkLifecycleUpdateResult {
	"""Number of releases that were bumped to the target lifecycle."""
	releasesBumped: Int!
	"""UUIDs of the bumped releases (caller can re-fetch for fresh state)."""
	releaseUuids: [ID!]!
}

type LicensePayload {
	baseUri: String
	validFrom: DateTime
	validTo: DateTime
	maxWriteUsers: Int
	maxReadUsers: Int
	globalUserCounts: GlobalUserCounts
}

type GlobalUserCounts {
	writeUsers: Int
	readUsers: Int
	totalUsers: Int
}

type SystemInfoIsSet {
	emailDetailsSet: Boolean
	defaultOrg: ID
	defaultOrgDetails: Organization
	# vulncheckKevConfigured dropped in V54 KEV per-org refactor; surfaced
	# per-org via the Integrations Catalog cards on Organization Settings.
}

type Organization {
	uuid: ID
	name: String
	type: OrganizationType
	approvalRoles: [ApprovalRole]
	terminology: Terminology
	ignoreViolation: IgnoreViolation
	settings: Settings
	createdType: ProgrammaticType
	lastUpdatedBy: ID
	createdDate: DateTime
	"""
	Org-wide PR-validation trigger rules. Each rule maps a regex over
	{@code VcsRepository.uri} (matched fully-anchored, see {@link
	GlobalPrValidationTriggerRule.uriPattern}) to an EXTERNAL_VALIDATION
	trigger that should apply when a VCS in the org has no per-repo
	override. List order is the priority order -- the first matching
	rule wins, and the per-VCS resolver surfaces the losing rule names
	for operator clean-up. SAAS-only.
	"""
	globalPrValidationTriggerRules: [GlobalPrValidationTriggerRule]
	"""
	Org-wide approval-policy assignment rules. Each rule maps a regex
	over {@code Component.name} (matched fully-anchored) plus a
	{@code componentType} filter to an approval-policy UUID. When a
	component has no per-component policy reference (or it points to
	an archived/missing policy), the resolver walks this list in order
	and the first matching rule's policy becomes the effective policy.
	List order is the priority order -- first match wins; the per-
	Component resolver surfaces the losing rule names for operator
	clean-up. SAAS-only.
	"""
	globalApprovalPolicyRules: [GlobalApprovalPolicyRule]
}

"""
Org-wide PR-validation trigger rule. See
{@link Organization.globalPrValidationTriggerRules} for the priority
contract; see {@link VcsRepository.effectivePrValidationTrigger} for
how rules are resolved per repo.
"""
type GlobalPrValidationTriggerRule {
	"""Display name; unique within the org."""
	name: String
	"""
	Java regex matched against {@code VcsRepositoryData.uri} via
	{@code Pattern.matcher(uri).matches()} -- fully anchored. Operators
	write {@code github.com/myorg/.*} (no leading {@code ^}, no
	trailing {@code $}) and the engine anchors automatically.
	"""
	uriPattern: String
	"""
	Trigger spec. Same shape as a per-VCS trigger; must be of type
	EXTERNAL_VALIDATION and reference a GITHUB integration with the
	PR_VALIDATE capability in the same org.
	"""
	trigger: ReleaseOutputEvent
}

input GlobalPrValidationTriggerRuleInput {
	name: String!
	uriPattern: String!
	trigger: ReleaseOutputEventInput!
}

"""
Org-wide approval-policy assignment rule. See
{@link Organization.globalApprovalPolicyRules} for the priority
contract and {@link Component.effectiveApprovalPolicy} for how rules
are resolved per component.
"""
type GlobalApprovalPolicyRule {
	"""Display name; unique within the org."""
	name: String
	"""
	Java regex matched against {@code Component.name} via
	{@code Pattern.matcher(name).matches()} -- fully anchored. Operators
	write {@code frontend-.*} (no leading {@code ^}, no trailing
	{@code $}) and the engine anchors automatically.
	"""
	namePattern: String
	"""
	Type filter. {@code COMPONENT} / {@code PRODUCT} restrict the
	match; {@code ANY} (also the default when null) matches both
	concrete component types.
	"""
	componentType: ComponentType
	"""Referenced approval policy UUID."""
	approvalPolicy: ID
	"""Hydrated approval policy. Null when the referenced policy is missing/archived."""
	approvalPolicyDetails: ApprovalPolicy
}

input GlobalApprovalPolicyRuleInput {
	name: String!
	namePattern: String!
	componentType: ComponentType
	approvalPolicy: ID!
}

"""
Resolved approval policy snapshot for a Component. See
{@link Component.effectiveApprovalPolicy}.
"""
type EffectiveApprovalPolicy {
	source: ApprovalPolicySource
	approvalPolicy: ID
	approvalPolicyDetails: ApprovalPolicy
	ruleName: String
	alsoMatchedRuleNames: [String]
	perComponentPolicyArchived: Boolean
}

enum ApprovalPolicySource {
	"""Per-component approvalPolicy reference is set and the policy still exists."""
	PER_COMPONENT
	"""Inherited from an org-wide GlobalApprovalPolicyRule."""
	ORG_RULE
	"""Neither per-component nor any matching org rule -- no approval policy is in effect."""
	NONE
}

type Terminology {
	featureSetLabel: String
}

type IgnoreViolation {
	licenseViolationRegexIgnore: [String]
	securityViolationRegexIgnore: [String]
	operationalViolationRegexIgnore: [String]
}

type Settings {
	justificationMandatory: Boolean
	branchSuffixMode: BranchSuffixMode
	vexComplianceFramework: VexComplianceFramework
	"""
	Org-level mode for sid (Software IDentification) PURL emission. See SidPurlMode docs.
	Null is treated as DISABLED at resolution time.
	"""
	sidPurlMode: SidPurlMode
	"""
	Decoded authority segments used when emitting platform sid PURLs. The first segment is
	the authority (domain or registered name); subsequent segments are publisher / business
	unit / product line context. Required when sidPurlMode == ENABLED_STRICT; optional under
	ENABLED_FLEXIBLE (used as a fallback when components/perspectives don't supply their own);
	must be null/empty under DISABLED.
	"""
	sidAuthoritySegments: [String!]
	"""
	Retention window, in days, for the org's notification rows (outbox events,
	deliveries, read marks). Null means the 90-day default.
	"""
	notificationRetentionDays: Int
}

"""
Org-level sid PURL emission policy. D11 / D15.
- DISABLED: no sid emission; tenant-supplied pkg:sid/... values pass through unchanged.
- ENABLED_STRICT: sid emitted org-wide; component/perspective overrides not honored;
  the org authority applies to every internal component.
- ENABLED_FLEXIBLE: sid emitted org-wide, but components and (SaaS) perspectives
  may override the per-component decision and supply their own authority.

Enabling sid is forward-only -- releases created before the toggle retain their
existing identifiers unchanged.
"""
enum SidPurlMode {
	DISABLED
	ENABLED_STRICT
	ENABLED_FLEXIBLE
}

"""
Component- and perspective-level sid override. Only honored when the org is in
ENABLED_FLEXIBLE; the mutation layer rejects ENABLE/DISABLE writes when the org
is STRICT or DISABLED. INHERIT (and null) defer to the next level up.
"""
enum SidPurlOverride {
	INHERIT
	ENABLE
	DISABLE
}

"""
Internal/external classification of a component (D16). EXTERNAL components are
third-party dependencies tracked inside the tenant's org and never receive a
platform-stamped sid PURL -- stamping the tenant's authority on third-party
software would be a falsified vendor claim. Defaults to INTERNAL on create.
"""
enum BelongsToOrganization {
	INTERNAL
	EXTERNAL
}

"""
VEX compliance framework layered on top of the CycloneDX baseline data model.
NONE  = pure CycloneDX, no extra validation.
CISA  = CISA VEX minimum requirements
        (https://www.cisa.gov/sites/default/files/2023-04/minimum-requirements-for-vex-508c.pdf).
"""
enum VexComplianceFramework {
	NONE
	CISA
}

"""
Controls whether non-base branches append a branch-derived suffix to
semver, four-part, and calver versions.
- APPEND: append branch namespace (e.g., 1.2.3-feat_x)
- NO_APPEND: do not append; conflicts resolved via -0, -1, ... suffix
- APPEND_EXCEPT_FOLLOW_VERSION: append for all branches and feature sets,
  except those with at least one follow-version dependency (treated as NO_APPEND for such branches)
- INHERIT: component-level only; defer to organization setting. Not valid at organization level.
"""
enum BranchSuffixMode {
	APPEND
	NO_APPEND
	APPEND_EXCEPT_FOLLOW_VERSION
	INHERIT
}

type AdminOrganization {
