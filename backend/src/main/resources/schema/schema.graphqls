	"""As-produced resolution of the release HBOM's CDX #929 choice slots."""
	choiceResolutions: [ChoiceResolution]
	manufactureDate: String
	expiryDate: String
	notes: String
	createdDate: DateTime
}

input ShipProductInput {
	org: ID!
	site: ID!
	featureSet: ID!
	release: ID!
	deliverable: ID
	shipDate: String
	quantity: Int
	identifiers: [IdentifierInput]
	choiceResolutions: [ChoiceResolutionInput]
	manufactureDate: String
	expiryDate: String
	notes: String
}

"""Expected/asserted state of a device (defaults from its shipment's release)."""
type DevicePlan {
	expectedRelease: ID
}

input DevicePlanInput {
	expectedRelease: ID
}

"""
An individual fielded unit -- the optional per-unit layer below a shipment.
Instance-like: plan (expected version) vs actual (phone-home) + 821 tracking.
"""
type Device {
	uuid: ID
	org: ID
	"""Soft-delete marker: ARCHIVED rows are hidden from listings."""
	status: Status
	shippedProduct: ID
	site: ID
	"""Unit-level identifiers (SERIAL, UDI, UDI-PI, ...)."""
	identifiers: [Identifier]
