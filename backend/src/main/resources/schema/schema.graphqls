	branches: [BranchWithReleases]
}

"""Bounded CVE search response — components built from the shownReleases newest matches."""
type CveSearchResult {
	components: [ComponentWithBranches]
	totalReleases: Int!
	shownReleases: Int!
	truncated: Boolean!
}

type ChildComponent {
	uuid: ID
	status: Status
