enum ViolationType {
	LICENSE
	SECURITY
	OPERATIONAL
}

enum VulnerabilitySeverity {
	CRITICAL
	HIGH
	MEDIUM
	LOW
	UNASSIGNED
}

enum AnalysisState {
	EXPLOITABLE
	IN_TRIAGE
	FALSE_POSITIVE
	NOT_AFFECTED
	RESOLVED
}

# CycloneDX 1.7 analysis.response values - declares the supplier action
# against an affecting vulnerability (CISA VEX "action statement").
enum AnalysisResponse {
	CAN_NOT_FIX
	WILL_NOT_FIX
	UPDATE
	ROLLBACK
	WORKAROUND_AVAILABLE
}

# Vulnerability ID types based on OSV schema
# See: https://ossf.github.io/osv-schema/
enum VulnerabilityAliasType {
	CVE       # CVE-YYYY-NNNNN
	GHSA      # GHSA-xxxx-xxxx-xxxx
	GO        # GO-YYYY-NNNN
	PYSEC     # PYSEC-YYYY-NNN
	RUST      # RUSTSEC-YYYY-NNNN
	OSV       # OSV-YYYY-NNN
	DSA       # DSA-NNNN-N (Debian)
	DLA       # DLA-NNNN-N (Debian LTS)
	RHSA      # RHSA-YYYY:NNNN (Red Hat)
	RHBA      # RHBA-YYYY:NNNN (Red Hat Bug Advisory)
	RHEA      # RHEA-YYYY:NNNN (Red Hat Enhancement Advisory)
	ALAS      # ALAS-YYYY-NNNN (Amazon Linux)
	ALAS2     # ALAS2-YYYY-NNNN (Amazon Linux 2)
	ALPINE    # ALPINE-CVE-YYYY-NNNN
	CGA       # CGA-xxxx-xxxx-xxxx (Chainguard)
	MAL       # MAL-YYYY-NNNN (Malicious packages)
	GSD       # GSD-YYYY-NNNNN
	OTHER
}

enum SeveritySource {
	NVD
	GHSA
	ANALYSIS
	OTHER
}

type FindingSourceDto {
	artifact: ID
	release: ID
	variant: ID
	analysisState: AnalysisState
	analysisDate: DateTime
	releaseDetails: Release
	artifactDetails: Artifact
}

type VulnerabilityAliasDto {
	type: VulnerabilityAliasType
	aliasId: String
}

type SeveritySourceDto {
	source: SeveritySource
	severity: VulnerabilitySeverity
}

type Vulnerability {
	purl: String
	vulnId: String
	severity: VulnerabilitySeverity
	aliases: [VulnerabilityAliasDto]
	sources: [FindingSourceDto]
	severities: [SeveritySourceDto]
	analysisState: AnalysisState
	analysisDate: DateTime
	attributedAt: DateTime
	"True when this vulnerability (by CVE id or alias) is in the CISA KEV catalog"
	knownExploited: Boolean
}

type Violation {
	purl: String
	type: ViolationType
	license: String
	violationDetails: String
	sources: [FindingSourceDto]
	analysisState: AnalysisState
	analysisDate: DateTime
	attributedAt: DateTime
}

type Weakness {
	cweId: String
	ruleId: String
	location: String
	fingerprint: String
	severity: VulnerabilitySeverity
	sources: [FindingSourceDto]
	analysisState: AnalysisState
	analysisDate: DateTime
	attributedAt: DateTime
}

