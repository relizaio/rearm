type VcsRepository {
	uuid: ID
	name: String
	org: ID
	uri: String
	type: String
	createdType: ProgrammaticType
	lastUpdatedBy: ID
	createdDate: DateTime
	"""
	Pull-request-level output triggers for this VCS repository. Currently
	constrained to ≤1 entry of type EXTERNAL_VALIDATION — used by the PR
	aggregator to dispatch the aggregated check-run verdict to the SCM.
	"""
	outputTriggers: [ReleaseOutputEvent]
	"""
	Resolved PR-validation trigger for this repo. Per-repo
	{@code outputTriggers} always wins; otherwise the org-wide rule
	list is walked in order and the first match's trigger is returned.
	{@code source} discriminates between the two; {@code ruleName} is
	set only when source = ORG_RULE; {@code alsoMatchedRuleNames}
	carries any later-list rules whose pattern also matched (for the
	provenance UI's "rules X, Y also match; X wins" warning);
	{@code staleRuleNames} flags rules that matched but reference a
	missing/archived integration and were therefore skipped.
	"""
	effectivePrValidationTrigger: EffectivePrValidationTrigger
}

"""
Resolved PR-validation trigger snapshot for a VCS repository. See
{@link VcsRepository.effectivePrValidationTrigger}.
"""
type EffectivePrValidationTrigger {
	source: PrValidationTriggerSource
	trigger: ReleaseOutputEvent
	ruleName: String
	alsoMatchedRuleNames: [String]
	staleRuleNames: [String]
}

enum PrValidationTriggerSource {
	"""Per-repo trigger configured directly on this VCS row."""
	PER_VCS
	"""Inherited from an org-wide GlobalPrValidationTriggerRule."""
	ORG_RULE
	"""Neither per-repo nor any matching org rule — no verdict will be dispatched."""
	NONE
}

"""
First-class PullRequest entity. Owns its own identity at the SCM level
(target VCS + identity string), its own commit list (SCE UUIDs), and
both inbound (release_validation_events) and outbound
(pr_validation_events) event streams.
"""
type PullRequest {
	uuid: ID
	org: ID
	targetVcsRepository: ID
	sourceVcsRepository: ID
	identity: String
	state: String
	title: String
	sourceBranchName: String
	targetBranchName: String
	endpoint: String
	commits: [ID]
	prCreatedDate: DateTime
	closedDate: DateTime
	mergedDate: DateTime
	createdDate: DateTime
	prValidationEvents: [PullRequestValidationEvent]
	releaseValidationEvents: [ReleaseValidationEvent]
	"""
	Releases currently attributed to this PR — every release whose
	primary sourceCodeEntry is one of the PR's commits, scoped to
	the PR's org. Same logic the aggregator uses to compute the
	PR-level verdict (no dispatch is triggered). Empty when the PR
	has no commits or no releases have been minted against any of
	them yet.
	"""
	attributedReleases: [Release]
	"""
	Hydrated commit list — SCE rows for every entry in `commits`.
	Order matches `commits` (head is the last element). Used by the
	UI to render the actual git commit SHA / message / author
	instead of just the SCE UUID. Missing SCEs (e.g. one that was
	since archived) are silently dropped.
	"""
	commitDetails: [SourceCodeEntry]
	"""
	Releases referenced by any release_validation_event in this PR's
	history — superset of attributedReleases. Required so the UI can
	display release names for events whose release has since been
	superseded (newest-per-component attribution drops the older
	release from attributedReleases but its event row remains).
	Distinct on UUID; missing releases (archived) are silently dropped.
	"""
	validatedReleaseDetails: [Release]
	"""
	Latest pr_validation_event verdict whose sourceCodeEntry matches
	the PR's current head commit. Mirrors the aggregator's
	"latest-for-head" lookup so this resolver and the SCM dispatch
	read the same value. {@code null} when the PR has no commits, no
	validation events, or no event for the current head — UI should
	render that as "pending / not yet validated".
	"""
	currentValidationState: ValidationState
}

type PullRequestValidationEvent {
	date: DateTime
	validationState: ValidationState
	comment: String
	sourceCodeEntry: ID
	attributedReleases: [ID]
}

type ReleaseValidationEvent {
	release: ID
	date: DateTime
	validationResult: ValidationState
}

enum ValidationState {
	SUCCESS
	FAILURE
	NEUTRAL
	SKIPPED
	CANCELLED
	"""
	Internal "verdict not yet computable" state — recorded on
	pr_validation_events when at least one release attributed to the
	PR has no validation event yet. Never dispatched to the SCM
	(GitHub doesn't have a matching check-run conclusion); the prior
	terminal verdict's check-run stays in place until a new terminal
	verdict supersedes it.
	"""
	PENDING
}

