#
# AI-Agent monitoring types. Backed by rearm.agents +
# rearm.agent_sessions + rearm.model_ontologies (V37 + V38). Shared
# (CE-included) GraphQL surface; policies / enforcement that wrap
# these arrive in PR 4 behind the SAAS package boundary. Full design
# rationale in backend/ai-plans/agentic/README.md.
#

"""
A coding agent registered to an org. ROOT agents are what an
external tool registers as and own sessions; SUB agents are
children a ROOT spawns and share the parent's session.

Identity = (org, lower(name)). Auto-registered on the first session
a calling FREEFORM key opens with a previously-unknown name in the
org. {@code model} points to a ModelOntology row carrying the
publisher / model / version / CycloneDX ML-BOM model card -- many
agents may share a model.
"""
type Agent {
	uuid: ID
	org: ID
	"""
	Registration key supplied by the runtime via --agent-name. Part of
	the (org, agentIdentity, lower(name)) resolution key -- treat as
	immutable. User-facing renames go through displayName.
	"""
	name: String
	"""
	Optional admin-chosen label shown in the UI in place of name. Falls
	back to name when null. Cosmetic only -- never used for resolution
	or uniqueness.
	"""
	displayName: String
	"""
	Resolved label the UI should render. Precedence (strongest last):
	name → first bound FREEFORM key note → displayName. I.e.
	displayName if set, else the note on a bound FREEFORM key, else name.
	Read-only -- set displayName to override.
	"""
	effectiveDisplayName: String
	"""ModelOntology row this agent runs."""
	model: ModelOntology @deprecated(reason: "Model is a property of the chat, not the durable agent. Read Session.primaryModel instead; this returns the agent's last-seen declared model as a transitional fallback.")
	"""Optional dashboard glyph."""
	iconKind: String
	"""Optional dashboard accent colour (CSS hex)."""
	color: String
	"""Free-form notes the user sets on the dashboard."""
	notes: String
	"""
	AgentIdentity row that scopes this agent. (org, agentIdentity,
	lower(name)) is the uniqueness boundary -- two different identities
	can each own a "Claude Code". SUB agents inherit their root's
	identity.
	"""
	agentIdentity: ID
	status: AgentStatus
	agentType: AgentType
	"""ROOT for top-level agents; SUB pointers point at the owning root."""
	rootAgent: ID
	"""Direct children spawned by this agent (best-effort report)."""
	subAgents: [ID]
	createdDate: DateTime
	# --- monitoring read-side (PR 3) ---
	"""
	OPEN sessions owned by this ROOT agent. Empty list on SUB agents
	(sub-agents do not own sessions). Returns the same ordering as
	{@code sessionsOfAgent} -- most recently active first.
	"""
	openSessions: [Session]
	"""
	CLOSED sessions owned by this ROOT agent. Same ordering as
	{@code openSessions}.
	"""
	closedSessions: [Session]
	"""
	Open + closed session counts for this agent. Cheaper than walking
	the full lists when the dashboard only needs the badges.
	"""
	sessionCounts: AgentSessionCounts
	"""
	Most-recent activity timestamp across all sessions this agent
	owns. Drives the dashboard "connected" pill. Null when the agent
	has no sessions yet.
	"""
	lastActivityAt: DateTime
	"""
	Enrolled public keys this agent signs commits with. Includes
	revoked entries -- UI filters by revokedAt for display, the
	verifier filters at lookup time.
	"""
	signingKeys: [SigningKey]
	"""
	FREEFORM API keys bound to this agent's identity
	(agent_identity_credentials of type REARM_API_KEY). These are the
	keys an agent runtime authenticates with to drive this agent.
	"""
	boundApiKeys: [ApiKey]
}

type AgentSessionCounts {
	openSessions: Int
	closedSessions: Int
}

"""
A single agent-policy evaluation outcome on a session. SAAS-only --
on CE deployments the session's {@code policyEvents} list is always
empty. Persisted append-only on AgentSession.
"""
type PolicyEvent {
	"""UUID of the AgentPolicy that produced this verdict."""
	policyUuid: ID
	"""Snapshot of the policy's name at evaluation time (denormalised so a renamed/deleted policy still surfaces sensibly)."""
	policyName: String
	kind: PolicyKind
	severity: PolicySeverity
	state: PolicyState
	"""Operator-facing failure message; null on PASSED verdicts."""
	message: String
	evaluatedAt: DateTime
	"""
	Full snapshot of the AgentPolicy that produced this verdict (CEL,
	description, current enabled flag). Lets a calling agent decide
	whether the failure is recoverable on its own (e.g. attach an
	orientation artifact and retry) or needs operator action (e.g.
	a "model must equal claude-opus" policy when the agent runs
	another model). Resolved at read time from the policyUuid; null
	if the policy was deleted after the event.
	"""
	policy: AgentPolicy
}

enum PolicyKind {
	"""Evaluated on session initialize + on artifact attach."""
	INPUT
	"""Evaluated on commit attribution and on artifact attach. Verdict locks at commit-attribution time."""
	OUTPUT
	"""
	Stays AWAITING through the entire session lifetime; verdict locks
	only at session close. Use when the gate depends on an artifact
	the agent doesn't file until its final step -- for example, a
	FINAL agentic-report tag that by definition arrives after the
	last commit. OUTPUT in that case would harden to FAILED before
	the report ever lands.
	"""
	CLOSE
}

enum PolicySeverity {
	"""Input failure rejects session init."""
	BLOCK
	"""Failure is recorded as a WARNING verdict; never throws."""
	WARN
}

enum PolicyState {
	PASSED
	WARNING
	FAILED
	"""
	Soft signal: the policy hasn't reached a terminal verdict for this
	session yet. Emitted at session init / artifact attach for OUTPUT
	policies that haven't been satisfied, and as a fallback when the
	evaluator hits a runtime error (the policy will be retried at the
	next eligible event). Renamed from PENDING to avoid name collision
	with rebom's EnrichmentStatus.PENDING in adjacent code.
	"""
	AWAITING
}

"""
SAAS-only AI-Agent policy. CEL expression evaluates against the
session context -- {@code session.*}, {@code agent.*},
{@code model.*}. **Match-to-block semantics** (same as component-level
CEL gates): the CEL describes the *failure* condition. Returns true
when the failure matches → the verdict on the session goes to FAILED
/ WARNING / PENDING per {@link #severity} + {@link #kind}. Returns
false → PASSED.
"""
type AgentPolicy {
	uuid: ID
	org: ID
	name: String
	description: String
	kind: PolicyKind
	severity: PolicySeverity
	"""CEL boolean expression -- true means the failure matches."""
	cel: String
	enabled: Boolean
	createdDate: DateTime
}

input AgentPolicyInput {
	"""null on create; existing uuid on update."""
	uuid: ID
	org: ID!
	name: String!
	description: String
	kind: PolicyKind!
	severity: PolicySeverity!
	cel: String!
	enabled: Boolean
}

# ===== Distribution module (SAAS-only) -- Client + Site =====

"""Contact / establishment details (821 consignee-chain fields)."""
type Contact {
	address: String
	phone: String
	email: String
}

input ContactInput {
	address: String
	phone: String
	email: String
}

"""Industry framing for a distribution; drives UI terminology per client."""
enum DistributionDomain {
	GENERIC
	MEDICAL
	DEFENSE
}

"""A customer / establishment that receives shipments. Parent of Site."""
type Client {
	uuid: ID
	org: ID
	"""Soft-delete marker: ARCHIVED rows are hidden from listings."""
	status: Status
	name: String
	domain: DistributionDomain
	contact: Contact
	notes: String
	createdDate: DateTime
}

input ClientInput {
	"""null on create; existing uuid on update."""
	uuid: ID
	org: ID!
	name: String!
	domain: DistributionDomain
	contact: ContactInput
	notes: String
}

"""A physical location belonging to a Client. Flat child (no nesting)."""
type Site {
	uuid: ID
	org: ID
	"""Soft-delete marker: ARCHIVED rows are hidden from listings."""
	status: Status
	client: ID
	name: String
	contact: Contact
	notes: String
	createdDate: DateTime
}

input SiteInput {
	"""null on create; existing uuid on update."""
