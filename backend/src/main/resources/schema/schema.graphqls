	GS1
	HIBCC
	ICCBBA
}

"""GUDID submission workflow state for a UDI-bearing release."""
enum GudidStatus {
	NOT_SUBMITTED
	SUBMITTED
	PUBLISHED
}

"""Stable GUDID descriptors carried at component level, inherited by releases."""
type GudidDefaults {
	brandName: String
	companyName: String
	gmdnCode: String
