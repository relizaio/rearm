	syncDtrackProjects(orgUuid: ID!): Boolean
	# Admin-only force re-upload: re-submit every synthetic bucket to DTrack
	# (existing project or a new one), triggering full re-analysis + re-ingest.
	forceReuploadDtrackData(orgUuid: ID!): Boolean

