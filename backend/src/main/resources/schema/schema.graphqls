	org: ID!
	client: ID!
	name: String!
	contact: ContactInput
	notes: String
}

"""821 disposition lifecycle of a shipped (tracked) unit."""
enum Disposition {
	SHIPPED
	RECEIVED
	RETURNED
	EXPLANTED
	DISPOSED
	DONATED
	LOST
}

"""Where an actual report came from."""
enum ReportSource {
	PHONE_HOME
	MANUAL
	SUPPORT_TICKET
}

"""821 tracking block -- meaningful for MEDICAL_TRACKED devices only. Per-device."""
type TrackingRecord {
	receivedDate: String
	patientId: String
	disposition: Disposition
	dispositionDate: String
}

input TrackingInput {
	receivedDate: String
	patientId: String
	disposition: Disposition
	dispositionDate: String
}

"""Phone-home / observed actual state (optional, expected-empty). Per-device."""
type ActualReport {
	reportedRelease: ID
	reportedAt: DateTime
	source: ReportSource
}

input ActualReportInput {
	reportedRelease: ID
	reportedAt: DateTime
	source: ReportSource
}

"""
An append-only, batch-level Distribution-module shipment record. Per-unit
observed state (actual / tracking) lives on the optional Device child.
"""
type ShippedProduct {
	uuid: ID
	org: ID
	"""Soft-delete marker: ARCHIVED rows are hidden from listings."""
	status: Status
	site: ID
	featureSet: ID
	release: ID
	deliverable: ID
	shipDate: String
	quantity: Int
	"""Batch-level production identifiers (LOT, UDI-DI, ...)."""
