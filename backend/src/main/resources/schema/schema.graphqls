}

type ReleaseInputEvent {
	uuid: ID
	name: String
	"""
	Output events fired when {@link #celExpression} evaluates to TRUE.
	"""
	outputEvents: [ID]
	"""
	Output events fired when {@link #celExpression} evaluates to FALSE.
	Optional -- leaving this empty preserves the legacy single-branch
	behavior (rule does nothing when CEL is false). When set, this gives
	operators a way to express "if X then A else B" in one rule instead
	of two competing rules. Both branches are skipped together when the
	rule is disabled or when the component opts out via its
	GlobalInputEventRef.
	"""
	outputEventsOnFalse: [ID]
	scope: EventScope
	celExpression: String
	"""
	Rule-level enable/disable. Defaults true. When false, the rule is
	skipped at evaluation time for every release that resolves against
	the owning approval policy, overriding any per-component
	GlobalInputEventRef.disabled state. Applies identically to component-
	local rules under Component.releaseInputTriggers.
	"""
	enabled: Boolean
	"""
	Optional rule-level precondition CEL. When non-empty, evaluated
	BEFORE {@link #celExpression}; if the precondition returns false
	(or throws), the rule is skipped entirely (neither matched- nor
	else-branch actions fire) and the PR conditions snapshot renders
	PENDING. Lets operators express "is this rule applicable yet?"
	separately from "did the condition match?". Necessary for rules
	with {@link #outputEventsOnFalse} populated because the false
	branch would otherwise fire on releases with missing data --
	canonical example: gate metrics-based rules on
	{@code release.firstScanned == true}.
	"""
	preconditionCelExpression: String
}

type ReleaseOutputEvent {
	uuid: ID
	name: String
	type: EventType
	toReleaseLifecycle: ReleaseLifecycleEnum
	integration: ID
	users: [ID]
	notificationMessage: String
  	vcs: ID
    eventType: String
    clientPayload: String
    celClientPayload: String
    schedule: String
    scope: EventScope
    includeSuppressed: Boolean
    snapshotApprovalEntry: ID
    snapshotLifecycle: ReleaseLifecycleEnum
    approvedEnvironment: String
    """
    Override the check-run name reported to the SCM for EXTERNAL_VALIDATION
    events. Defaults to `rearm/<componentName>` when null/empty. Set this
    when an org-wide branch-protection rule needs a single unified
    required-check entry (GitHub matches by exact string -- no wildcards).
    """
    checkName: String
}

type GlobalInputEventRef {
	uuid: ID
	"""
	Opt-out flag -- under the opt-out semantics introduced May 2026, every
	policy rule fires for every component using the policy unless the
	component has a ref with disabled=true. See ComponentData.GlobalInputEventRef.
	"""
	disabled: Boolean
	overrideOutputEventsLocally: Boolean
	outputEventsOverride: [ID]
}

