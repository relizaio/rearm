	ARCHIVED
	COMPLETE
	DRAFT
	IGNORED
	# Schedule-driven workload (k8s Job / CronJob etc.). Included in
	# the instance plan CDX so the operator sees the version that
	# last ran, but excluded from product-release matching entirely.
	# The deployed version may lag the target until the job next
	# runs, and the system does not flag that as a mismatch.
	# Distinct from TRANSIENT (which still requires version agreement
	# when both sides have the dep) and IGNORED (which is fully
	# omitted from the CDX).
	JOB
	OPTIONAL
	PENDING
	REJECTED
	REQUIRED
	TRANSIENT
}

