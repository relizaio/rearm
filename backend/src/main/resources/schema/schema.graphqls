"""Regulatory classification of a component / device (Distribution module)."""
enum DeviceClass {
	NONE
	MEDICAL_UNTRACKED
	MEDICAL_TRACKED
}

"""
Resolved device identity for a feature set: its effective UDI-DI and
regulatory class, derived from the single UDI-bearing constituent component.
"""
type DeviceIdentity {
	featureSet: ID
	deviceClass: DeviceClass
	udiBearingComponent: ID
	udiBearingRelease: ID
	udiDi: String
}

"""
Cross-cutting KPIs for the AI Agents dashboard header (mockup's
four-card row).
"""
type AgentDashboardKpis {
	"""Count of OPEN sessions across the org."""
	activeSessions: Int
	"""Sessions closed within the last 30 days."""
	closedSessions30d: Int
	"""Artifact UUIDs attached to sessions active in the last 7 days. Sum, not distinct."""
	artifactsProduced7d: Int
	"""Total registered agents in the org (ROOT + SUB)."""
	registeredAgents: Int
}

enum AgentStatus {
	ACTIVE
	ARCHIVED
}

enum AgentType {
	ROOT
	SUB
}

"""
One ROOT Agent invocation. Many concurrent sessions per agent are
allowed on the same API key. Sub-agents of the root contribute
commits / artifacts to the same session via the commit-trailer
attribution path (PR 2).
"""
type Session {
	uuid: ID
	org: ID
	"""Owning ROOT agent uuid."""
	agent: ID
	"""
	Agent-supplied natural session id. Defaults to the row uuid when
	the agent didn't pick one on initialize. The two-line commit
	trailer references this value, not the row uuid.
	"""
	clientSessionId: String
	"""API key the agent used to open the session."""
	apiKey: ID
	title: String
	status: SessionStatus
	startedAt: DateTime
	closedAt: DateTime
	lastActivityAt: DateTime
	"""Artifact UUIDs attached to this session (reuses rearm.artifacts)."""
	artifacts: [ID]
	"""
	SCE UUIDs attributed to this session via the commit-trailer parser
	(PR 2). Order is append-order; head of list is the earliest commit.
	"""
	commits: [ID]
	"""
	Append-only log of agent-policy evaluations (PR 4). Empty on CE
	deployments and on sessions opened under an org with no policies.
	"""
	policyEvents: [PolicyEvent]
	"""
	Releases produced from this session's commits. Computed at read
	time by walking `commits → Release.sourceCodeEntry` (and
	`commits[]` for multi-commit releases). Distinct on release uuid.
	"""
	releases: [Release]
	"""
	Pull requests touched by this session's commits. Computed at read
	time by walking `commits → PullRequest.commits[]`. Distinct on
	PR uuid.
	"""
	pullRequests: [PullRequest]
	"""
	If this session was opened by an agent retrying after a prior
	BLOCKED / CLOSED predecessor, this is that predecessor's uuid.
	Null on first-time sessions.
	"""
	parentSession: ID
	"""
	The AI model this session ran. The model is a property of the chat,
	not the durable agent -- set from the agent's declared model on
	initialize. Null on legacy sessions written before per-session model
	tracking existed. Prefer this over the deprecated Agent.model.
	"""
	primaryModel: ModelOntology
	"""
	How much trust primaryModel carries. DECLARED = the agent self-
	reported the model string (the only source today). RUNTIME_OBSERVED is
	reserved for host-side hooks that read the model from the runtime's own
	record; not yet emitted. The UI must not imply the model carries the
	session signature's authority.
	"""
	modelAssertion: ModelAssertionState!
	createdDate: DateTime
}

"""
How much trust a session's recorded model carries -- see
Session.modelAssertion.
"""
enum ModelAssertionState {
	"""Agent self-reported the model string via the CLI; trusted but unverified."""
	DECLARED
	"""Model read from the runtime's own record (e.g. Claude Code transcript). Reserved for Path-B hooks; not yet emitted."""
	RUNTIME_OBSERVED
}

enum SessionStatus {
	OPEN
	CLOSED
	"""
	A BLOCK-severity INPUT policy failed on sessionInitializeProgrammatic.
	The row is persisted so the audit / dashboard show the rejected
	attempt with its policyEvents, but the trailer-attribution
	resolver refuses to bind commits against it -- trailers carrying
	this clientSessionId surface as REJECTED attribution. Terminal:
	the agent must mint a fresh, unique clientSessionId to retry.
	"""
	BLOCKED
}

"""
A row describing one AI/ML model an Agent runs. Identity =
(org, lower(name), version). Carries publisher + a full CycloneDX
ML-BOM model card (opaque jsonb). Auto-upserted on session
initialize from (agentVendor, agentModel, agentModelVersion).
"""
type ModelOntology {
	uuid: ID
	org: ID
	"""Model name, e.g. "claude-sonnet"."""
	name: String
	"""Model version, e.g. "4.5". Defaults to "unknown" on auto-registration when omitted."""
	version: String
	"""Publisher / vendor (e.g. "Anthropic"). Display-only."""
	publisher: String
	"""One-line summary for the dashboard tooltip."""
	description: String
	"""Optional canonical id (e.g. "pkg:huggingface/anthropic/claude-sonnet@4.5")."""
	purl: String
	"""
	CycloneDX ML-BOM model component (type machine-learning-model)
	stored opaquely. Empty {} on auto-registration; the user attaches
	a fuller card later via setModelOntologyModelCardProgrammatic.
	"""
	modelCard: Object
	notes: String
	createdDate: DateTime
}

input AgentUpdateInput {
	uuid: ID!
	name: String
	iconKind: String
	color: String
	notes: String
	status: AgentStatus
}

"""
One actionable event the agent owning a session needs to react to --
typically a release minted from the session's commits changing
lifecycle (REJECTED by a CEL gate, ASSEMBLED, etc.) or carrying a
new approval (DISAPPROVED with reviewer comment is the canonical
"agent fix loop" trigger). Polled by the agent via
{@code agentSessionInboxProgrammatic} with a cursor it stores
client-side.
"""
type AgentSessionInboxEvent {
	"""
	Opaque, monotone cursor token. Pass back as the {@code since}
	field on the next poll to fetch strictly newer events. Stable --
	the same event always returns the same cursor.
	"""
	cursor: String!
	occurredAt: DateTime!
	kind: AgentInboxEventKind!
	"""
	Release this event is about, when {@code kind} is release-side
	(LIFECYCLE_CHANGE / APPROVAL). Null on session-side events
	(POLICY_VERDICT).
	"""
	release: Release
	"""Previous value, when meaningful (e.g. prior lifecycle)."""
	oldValue: String
	"""New value (e.g. new lifecycle, "DISAPPROVED")."""
	newValue: String
	"""
	Free-form human-readable reason for the event:
	  - LIFECYCLE_CHANGE: the matching ReleaseUpdateEvent.message
	    (e.g. "Triggered by 'Reject when any commit is not VERIFIED'
	    (CEL: …)") -- what *caused* the lifecycle change.
	  - APPROVAL: the reviewer's free-text comment when
	    DISAPPROVED; null on APPROVED unless a comment was left.
	  - POLICY_VERDICT: the failing policy's failure message.
	"""
	reason: String
	source: AgentInboxSource!
	"""
	User uuid that authored the change, when {@code source = HUMAN}.
	Null for automated / policy-driven events.
	"""
	actorUuid: ID
	"""Approval role id ({@code ApprovalEntry.roleId} snapshot), when {@code kind = APPROVAL}."""
	actorRoleId: String
}

enum AgentInboxEventKind {
	"""A release's lifecycle moved (e.g. ASSEMBLED → REJECTED, PENDING → ASSEMBLED)."""
	LIFECYCLE_CHANGE
	"""An approval entry on a release flipped (APPROVED / DISAPPROVED / withdrawn)."""
	APPROVAL
	"""A new PolicyEvent landed on the session itself (post-init artifact-attach / commit-attribution re-eval)."""
	POLICY_VERDICT
}

enum AgentInboxSource {
	"""A human user performed the action (approval, manual lifecycle change)."""
	HUMAN
	"""An automated component-level output trigger fired (CEL gate matched)."""
	POLICY_GATE
	"""Lifecycle progressed by the system without an explicit trigger (e.g. initial release-created PENDING)."""
	RELEASE_AUTO
}

input AgentSessionInboxInput {
	sessionUuid: ID!
	"""
	Opaque cursor from a prior poll. Null = "from session start".
	Server returns events strictly after this cursor.
	"""
	since: String
	"""Optional filter; null = all kinds."""
	kinds: [AgentInboxEventKind!]
	"""Default 50; capped at 200."""
	limit: Int
}

input SessionInitializeInput {
	"""
	Display name the agent reports for itself ("Claude Code", "Cursor
	Agent"). Required -- used as the (org, lower(name)) lookup key.
	"""
	agentName: String!
	"""
	Model name the agent reports running ("claude-sonnet",
	"composer-1"). Required -- used as the (org, lower(name), version)
	lookup key on the ModelOntology row.
	"""
	agentModel: String!
	"""Model version (e.g. "4.5"). Defaults to "unknown" if omitted."""
	agentModelVersion: String
	"""Publisher / vendor (e.g. "Anthropic"). Display-only; stored on the ModelOntology row."""
	agentVendor: String
	agentIconKind: String
	agentColor: String

	"""
	Optional client-side session id. Defaults server-side to the row
	uuid when omitted. **Unique forever within (org, agent)**: an id
	previously used by ANY session (OPEN, CLOSED, or BLOCKED) cannot
	be re-used; sessionInitializeProgrammatic errors with
	clientSessionId-conflict. Agents that retry after a BLOCKED /
	CLOSED predecessor must mint a fresh id.
	"""
	clientSessionId: String

	title: String

	"""
	Optional pointer to a prior session this one continues from.
	Set when an agent retries after a BLOCKED or CLOSED predecessor
	so the audit trail threads the related attempts. Null on first-
	time sessions.
	"""
	parentSession: ID
}

"""
Upload one or more artifacts and bind them to an agent session.
Each {@code ArtifactInput.file} is a separate multipart part on the
HTTP body per the Apollo upload spec. The resulting artifact rows
carry {@code belongsTo=AGENT_SESSION} and live only on the session --
they do not appear on any release or component.
"""
input SessionAddArtifactInput {
	sessionUuid: ID!
	artifacts: [ArtifactInput!]!
}

input SessionUpdateMetaInput {
	uuid: ID!
	title: String
	clientSessionId: String
}

"""
Register a SUB agent under an existing parent. The parent may be
ROOT or SUB; the new sub's rootAgent is resolved to the parent's
owning root and its model ontology inherits from the parent unless
overridden.
"""
input SpawnSubAgentInput {
	parentUuid: ID!
	name: String!
	"""Optional model-ontology override. Defaults to the parent's model."""
	modelUuid: ID
	iconKind: String
	color: String
}

input ModelOntologyUpdateInput {
	uuid: ID!
	publisher: String
	description: String
	purl: String
	notes: String
}

"""
Attach (or replace) a CycloneDX ML-BOM model card on an ontology
row. The card is the {@code component} object of a CycloneDX
machine-learning model -- see the
[CycloneDX ML-BOM guide](https://github.com/CycloneDX/guides/tree/main/ML-BOM/en)
for the expected shape.
"""
input SetModelCardInput {
	modelOntologyUuid: ID!
	modelCard: Object!
}

# ============================================================
# Signature verification -- commit-level signatures (v1: SSH, GPG).
# Image / SBOM / X.509 land in v2. See backend/ai-plans/agentic/README §11.4.
# ============================================================

"""
A natural person (or external bot) whose commits show up in the
org's SCEs. Owns enrolled signing keys the verifier matches against.
May or may not be bound to a ReARM user -- the binding is optional so
external contributors and ex-employees are covered.
"""
type Committer {
	uuid: ID
	org: ID
	name: String
	email: String
	"""Optional binding to a ReARM users row."""
	user: ID
	"""Historical email aliases -- same committer, different addresses."""
	aliases: [String]
	status: CommitterStatus
	createdDate: DateTime
	"""Enrolled keys this committer owns. Includes revoked entries."""
	signingKeys: [SigningKey]
}

enum CommitterStatus {
	ACTIVE
	ARCHIVED
}

input CommitterInput {
	"""null on create; existing uuid on update."""
	uuid: ID
	org: ID!
	name: String!
	email: String!
	user: ID
	aliases: [String]
}

"""
Enrolled public key bound to an Agent or Committer. The verifier
matches signatures by fingerprint to this row and never trusts the
key embedded in a signature blob.
"""
type SigningKey {
	uuid: ID
	org: ID
	format: SignatureFormat
	ownerType: SigningKeyOwnerType
	ownerUuid: ID
	"""Normalised fingerprint -- SHA256:... for SSH, long key id for GPG."""
	fingerprint: String
	"""Principal string ssh-keygen expects via -I, or GPG user-id."""
	identity: String
	"""Wire-format pubkey -- single line SSH, ASCII-armoured GPG."""
	pubKey: String
	createdDate: DateTime
	revokedAt: DateTime
}

enum SignatureFormat {
	SSH
	GPG
	"""Reserved for v2 -- trust anchored at CA, not per-key."""
	X509
}

enum SigningKeyOwnerType {
	AGENT
	COMMITTER
}

input SigningKeyInput {
	org: ID!
	format: SignatureFormat!
	ownerType: SigningKeyOwnerType!
	ownerUuid: ID!
	"""SHA256:... for SSH; long key id for GPG. Derived from pubKey when omitted."""
	fingerprint: String
	"""Optional override; for COMMITTER owners defaults to committer.email."""
	identity: String
	"""Single-line SSH or ASCII-armoured GPG block."""
	pubKey: String!
}

"""
Programmatic (FREEFORM-auth'd) variant of SigningKeyInput with no {@code org}
field: the org is always the one the calling key resolves to, so accepting a
client-supplied org is redundant and a footgun (a mismatched value previously
surfaced as an opaque "Not authorized"). Used only by
{@code enrollSigningKeyProgrammatic}.
"""
input AgentSigningKeyInput {
	format: SignatureFormat!
	ownerType: SigningKeyOwnerType!
	ownerUuid: ID!
	"""SHA256:... for SSH; long key id for GPG. Derived from pubKey when omitted."""
	fingerprint: String
	"""Optional override; defaults to the agent's identity where applicable."""
	identity: String
	"""Single-line SSH or ASCII-armoured GPG block."""
	pubKey: String!
}

"""
Verdict snapshot for a (subject, signature-artifact) pair. CEL reads
the most-recent row via {@code commit.signature.*}.
"""
type SignatureVerification {
	uuid: ID
	org: ID
	subjectType: SignatureSubjectType
	subjectUuid: ID
	signatureArtifact: Artifact
	signedPayloadArtifact: Artifact
	publicKeyArtifact: Artifact
	format: SignatureFormat
	verdict: SignatureVerificationState
	"""Set on VERIFIED -- Agent or Committer that holds the matched key."""
	ownerType: SigningKeyOwnerType
	ownerUuid: ID
	"""Fingerprint of the matched enrolled key -- set on VERIFIED."""
	keyFingerprint: String
	verifiedAt: DateTime
	verifierVersion: Int
	"""Free-form diagnostic for the UI / debugging."""
	details: String
	createdDate: DateTime
}

enum SignatureSubjectType {
	SCE
	"""Reserved for v2 -- image / SBOM signature attestations."""
	ARTIFACT
}

enum SignatureVerificationState {
	"""No signature artifact attached."""
	UNSIGNED
	"""Cryptographic check passed and signer resolved to an enrolled key."""
	VERIFIED
	"""Cryptographic check failed."""
	INVALID_SIGNATURE
	"""Signature parsed but the signer key is not enrolled in this org."""
	UNKNOWN_KEY
	"""Signer key was matched but is revoked."""
	KEY_REVOKED
	"""Reserved for v2 -- attribution constraint failure decoupled from trust-store scope (e.g. image / attestation flows where the verifier's scope and the expected attribution can legitimately differ). Not produced in v1; the verifier narrows scope upfront from the SCE so a mismatched owner can't reach this branch."""
	WRONG_SIGNER
	"""Verification was scheduled but has not yet run."""
	PENDING
	"""Verifier subprocess errored -- see {@code details} for diagnostics."""
	ERRORED
}

"""
Compact CEL-facing view of an SCE's signature verdict. Surfaced as
{@code SourceCodeEntry.signature}; the underlying row lives in
signature_verifications.
"""
type SceSignature {
	state: SignatureVerificationState
	format: SignatureFormat
	signedByOwnerType: SigningKeyOwnerType
	signedByOwnerUuid: ID
	verifiedAt: DateTime
	keyFingerprint: String
}

"""A parsed HBOM hardware node (device/firmware) attached to a release."""
type HbomComponent {
	uuid: ID
	org: ID
	release: ID
	bomRef: String
	type: String
	"""CDX #929 choice operator (XOR / AND / OPTIONAL); null for plain devices."""
	operator: String
	name: String
	version: String
	description: String
	category: String
	subcategory: String
	"""CDX 2.0 parties (manufacturer/supplier/... incl. address), spec PR #930."""
	parties: [Party]
	"""Party-asserted identity claims (CDX 2.0 identity model, spec PR #936)."""
	identifiers: [ComponentIdentifier]
	"""Derived: part-number-like claims (MPN/PART_NUMBER/...), deduped."""
	partNumbers: [String]
	"""Derived: first MANUFACTURER-role party's name."""
	manufacturer: String
	boardLocation: String
	deviceType: String
	quantity: Int
	parentRef: String
	isRoot: Boolean
}

"""Identity claims of an HBOM component grouped by asserting party (CDX 2.0, spec PR #936)."""
type ComponentIdentifier {
	bomRef: String
	"""bom-ref of the Party making these identity assertions."""
	party: String
	identities: [Identifier]
}

# ===== Digital twin (Distribution) -- field events + observed software state =====

enum DeviceEventType {
	FAILURE
	REPAIR
	REPLACEMENT
	INSPECTION
	OBSERVATION
}

"""The part installed by a REPLACEMENT event."""
type ReplacementPart {
	"""Typed identity of the installed part (MPN/PART_NUMBER/...) plus unit production identifiers (LOT, SERIAL)."""
	identifiers: [Identifier]
	manufacturer: String
}

input ReplacementPartInput {
	identifiers: [IdentifierInput]
	manufacturer: String
}

"""
A field event on a fielded unit. Hardware events anchor to the release's HBOM
ontology via hbomRef; software events via purl. Append-only.
"""
type DeviceEvent {
	uuid: ID
	org: ID
	"""Soft-delete marker: ARCHIVED rows are hidden from listings."""
	status: Status
	device: ID
	eventType: DeviceEventType
	date: DateTime
	hbomRef: String
	componentName: String
	purl: String
	replacement: ReplacementPart
	"""For OBSERVATION events: the full reconciled report (history; the device's observedState is latest-only)."""
	observation: ObservedState
	notes: String
	createdDate: DateTime
}

input DeviceEventInput {
	device: ID!
	eventType: DeviceEventType!
	date: DateTime
	hbomRef: String
	componentName: String
	purl: String
	replacement: ReplacementPartInput
	notes: String
}

enum ObservedItemStatus {
	MATCHED
	DRIFTED
	FOREIGN_COMPONENT
	UNKNOWN
}

"""One reconciled observed item (e.g. a running container image digest)."""
type ObservedItem {
	identifier: String
	digest: String
	status: ObservedItemStatus
	deliverable: ID
	component: ID
	componentName: String
	observedRelease: ID
	observedVersion: String
	expectedRelease: ID
	expectedVersion: String
}

"""Latest observed software state, reconciled against the expected release tree."""
type ObservedState {
	reportedAt: DateTime
	source: ReportSource
	items: [ObservedItem]
	matchedCount: Int
	driftedCount: Int
	unknownCount: Int
}

input ObservedDigestInput {
	identifier: String
	digest: String!
}

"""
Programmatic phone-home payload: observed digests (structured) and/or a raw
text blob (e.g. a k8s image list) the backend extracts digests from.
"""
input DeviceStateReportInput {
	device: ID!
	source: ReportSource
	observed: [ObservedDigestInput]
	rawText: String
}

"""One HBOM node of a unit's as-maintained view (release HBOM + replacements)."""
type DeviceHbomComponent {
	component: HbomComponent
	"""ORIGINAL | REPLACED | ALTERNATE | UNRESOLVED_CHOICE"""
	twinStatus: String
	"""Latest field event on this node (FAILURE / REPAIR / INSPECTION / REPLACEMENT); null when none."""
	eventType: String
	eventDate: DateTime
	replacement: ReplacementPart
	eventNotes: String
	"""bom-ref of the CDX #929 choice slot this node belongs to (null otherwise)."""
	choiceRef: String
}

"""A CDX #929 choice slot of a release tree, with its option nodes."""
type ComponentChoice {
	choice: HbomComponent
	options: [HbomComponent]
}

"""One resolved choice slot of a produced lot (XOR: one ref; OPTIONAL: zero/one; AND: implicit)."""
type ChoiceResolution {
	choiceRef: String
	selectedRefs: [String]
}

input ChoiceResolutionInput {
	choiceRef: String!
	selectedRefs: [String]
}

"""One fleet-drift hit: a unit diverging from its authorized baseline, and where it is fielded."""
type FleetDriftEntry {
	device: Device
	siteName: String
	clientName: String
}
