# Vulnerability Analysis Types

type VulnAnalysisWebDto {
	uuid: ID!
	org: ID!
	responses: [AnalysisResponse!]
	recommendation: String
	workaround: String
	location: String!
	locationType: LocationType!
	findingId: String!
	findingAliases: [String]
	findingType: FindingType!
	scope: AnalysisScope!
	scopeUuid: ID!
	release: ID
	branch: ID
	component: ID
	analysisState: AnalysisState!
	analysisJustification: AnalysisJustification
	analysisHistory: [AnalysisHistoryWebDto]
	severity: VulnerabilitySeverity
	releaseDetails: Release
	branchDetails: Branch
	componentDetails: Component
}

type AnalysisHistoryWebDto {
	state: AnalysisState!
	justification: AnalysisJustification
	details: String
	createdDate: DateTime!
	severity: VulnerabilitySeverity
	responses: [AnalysisResponse!]
	recommendation: String
	workaround: String
}

input CreateVulnAnalysisInput {
	org: ID!
	location: String!
