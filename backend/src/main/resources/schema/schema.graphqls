	org: ID
	object: ID
	type: PermissionType
	scope: PermissionScope
	functions: [PermissionFunction]
	approvals: [String]
}

input CreateComponentInput {
	org: ID
	name: String!
	type: ComponentType!
	defaultBranch: String
	versionSchema: String
	marketingVersionSchema: String
	versionType: VersionType
	featureBranchVersioning: String
	vcs: ID
	vcsRepository: VcsRepositoryInput
	includeApi: Boolean
	approvalPolicy: ID
	identifiers: [IdentifierInput]
	# Distribution module: device classification + profiles + native identifiers.
	nature: ComponentNature
	deviceClass: DeviceClass
	medicalProfile: MedicalProfileInput
	repoPath: String
	branchSuffixMode: BranchSuffixMode
	"""
	Component-level sid override. Only writeable when the org is in ENABLED_FLEXIBLE;
	the mutation layer rejects ENABLE/DISABLE writes otherwise (D3).
	"""
	sidPurlOverride: SidPurlOverride
	"""
	Component-level authority segments. May be set even when sidPurlOverride is INHERIT --
	the segments only take effect once a higher level enables sid for this component.
	"""
	sidAuthoritySegments: [String!]
	"""
	Whether this component is the tenant's own software (INTERNAL) or a tracked
	third-party dependency (EXTERNAL). Defaults to INTERNAL when null. EXTERNAL
	components never receive a platform-stamped sid PURL (D16).
	"""
	isInternal: BelongsToOrganization
}

input UpdateComponentInput {
	uuid: ID
	name: String!
	kind: ComponentKind
	versionSchema: String
	marketingVersionSchema: String
	versionType: VersionType
	featureBranchVersioning: String
	vcs: ID
	approvalPolicy: ID
	"""
	Explicitly clear the per-component approvalPolicy reference. The
	default {@code null} on {@code approvalPolicy} means "leave the
	existing value alone" (server-side leave-unchanged convention), so
	a separate flag is needed to express "actually remove the assigned
	policy". When {@code true}, the server unsets the reference; the
	same guard as the change-policy path still applies (the component
	must not still reference globalInputEvents from the old policy).
	{@code approvalPolicy} is ignored when this flag is true.
	"""
	clearApprovalPolicy: Boolean
	releaseInputTriggers: [ReleaseInputEventInput]
	outputTriggers: [ReleaseOutputEventInput]
	globalInputEventRefs: [GlobalInputEventRefInput]
	identifiers: [IdentifierInput]
	# Distribution module: device classification + profiles + native identifiers.
	nature: ComponentNature
	deviceClass: DeviceClass
	medicalProfile: MedicalProfileInput
	repoPath: String
	authentication: ComponentAuthenticationInput
	branchSuffixMode: BranchSuffixMode
	"""
	Update component-level sid override. Null leaves the existing value unchanged.
	INHERIT clears the override (defers to higher level). Only writeable under
	org ENABLED_FLEXIBLE.
	"""
	sidPurlOverride: SidPurlOverride
	"""
	Update component-level authority segments. Null leaves the existing value unchanged.
	"""
	sidAuthoritySegments: [String!]
	"""
	Update internal/external classification (D16). Null leaves the existing value unchanged.
	"""
	isInternal: BelongsToOrganization
	"""Manually-assigned lead user UUIDs. Null leaves unchanged; empty list clears."""
	leads: [ID!]
	"""Freeform stakeholder contacts (HTML-sanitized server-side). Null leaves unchanged; empty list clears."""
	contacts: [ComponentContactInput!]
}

