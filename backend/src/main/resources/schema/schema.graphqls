# Capabilities a GITHUB integration is wired up to perform. Picked at
# create/update time, validated by the server, and used both as a UI
# filter (e.g. the "create webhook" picker only shows integrations with
# WEBHOOK) and as a runtime guard on outbound dispatch paths.
enum IntegrationCapability {
	WORKFLOW_DISPATCH
	PR_VALIDATE
	WEBHOOK
}

# Inbound GitHub webhook receiver. One row per Integration (one-to-one
# cardinality enforced server-side). The (org, slug) pair forms the
# public URL path /api/programmatic/v1/webhook/{org}/{slug}.
# encryptedSecret is intentionally not exposed back through the API —
# it's set-only on create / update.
type Webhook {
	uuid: ID
	org: ID
	integration: ID
	slug: String
	note: String
	status: WebhookStatus
	lastDeliveryAt: DateTime
	lastDeliveryStatus: WebhookDeliveryOutcome
	lastDeliveryId: String
	consecutiveFailureCount: Int
	createdDate: DateTime
	updatedDate: DateTime
}

input WebhookInput {
	org: ID!
	integration: ID!
	# Lowercase ASCII, 4-63 chars, no leading/trailing hyphen. Unique
	# within the org. Reserved values are rejected.
	slug: String!
	# Plain HMAC-SHA256 key (matches the value pasted into the GitHub
	# App's "Webhook secret" field). Encrypted at rest.
	secret: String!
	# GitHub installation ID (numeric, passed as string for symmetry
	# with the GH App's existing schedule field).
	installation: String
	note: String
}

input WebhookUpdateInput {
	uuid: ID!
	note: String
	status: WebhookStatus
	# Pass empty string to clear, omit to preserve.
	installation: String
	# Pass to rotate; omit to keep existing.
	secret: String
	# Pass to rename. Same regex + uniqueness rules as create. Changing
	# the slug also changes the public webhook URL — re-register it on
	# the GitHub App side at the same time.
	slug: String
}

enum WebhookStatus {
	ACTIVE
	DISABLED
}

enum WebhookDeliveryOutcome {
	SUCCESS
	SIGNATURE_INVALID
	HANDLER_ERROR
	UNKNOWN_EVENT
	DUPLICATE
	WEBHOOK_DISABLED
}

