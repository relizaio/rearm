# ========== Instance Types ==========

type Instance {
	uuid: ID
	uri: String
	org: ID
	name: String
	# Human-readable identifier resolved server-side. CLUSTER instances are
	# identified by `name`; STANDALONE_INSTANCE / CLUSTER_INSTANCE are
	# identified by `uri`. Falls back to the other field, then to the
	# stringified UUID, so this is always non-empty for any persisted
	# instance.
	displayName: String
	namespace: String
	instanceType: InstanceType
	status: Status
	notes: String
	spawnType: SpawnType
	instances: [ID]
	environment: String
	properties: [InstancePropertyRecord]
	releases: [DeployedRelease]
	targetReleases: [DeployedRelease]
	# Live snapshot of images reported by the watcher whose digest does
	# not resolve to any DeliverableData in this org. Replaced on each
	# tick -- pods that disappear drop off automatically. Surfaced as
	# "Unmatched Deployed Images" in the Instance UI so operators can
	# see what is running that ReARM does not know about.
	unmatchedReleases: [UnmatchedImage]
	agentData: String
	productPlans: [InstanceProductMapPlan]
	productActuals: [InstanceProductMapActual]
	createdType: ProgrammaticType
	lastUpdatedBy: ID
	createdDate: DateTime
}

type UnmatchedImage {
	image: String
	# Canonical (algo, hex, scope) digest records -- same shape used on
	# artifact.digestRecords. For k8s container images this is normally
	# one entry with algo=SHA-256, scope=OCI_STORAGE.
	digestRecords: [DigestRecord]
	namespace: String
	pod: String
	lastSeen: DateTime
	state: ServiceState
	replicas: [DeployedReplica]
}

type DeployedRelease {
	timeSent: DateTime
	release: ID
	deliverable: ID
	type: ProgrammaticType
	namespace: String
	properties: Object
	state: ServiceState
	replicas: [DeployedReplica]
	isInError: Boolean
	partOf: String
	releaseDetails: Release
}

type DeployedReplica {
	id: String
	state: ServiceState
}

type InstanceProductMapPlan {
	featureSet: ID
	featureSetDetails: Branch
	type: IntegrateType
	namespace: String
	targetRelease: ID
	targetReleaseDetails: Release
	identifier: String
	configuration: String
	alertsEnabled: Boolean
}

# Per-product slice of an instance plan: which feature set is currently
# deployed and which alternatives the caller could switch to. Returned
# by listInstanceProductFeatureSets.
type InstanceProductFeatureSets {
	namespace: String
	product: NamedRef!
	currentFeatureSet: NamedRef
	availableFeatureSets: [NamedRef!]!
}

type NamedRef {
	uuid: ID!
	name: String!
}

type InstanceProductMapActual {
	featureSet: ID
	featureSetDetails: Branch
	matchedRelease: ID
	matchedReleaseDetails: Release
	namespace: String
	identifier: String
	notMatchingSince: DateTime
}

type InstancePropertyRecord {
	uuid: ID
	type: PropertyConfigurableType
	value: String
	namespace: String
	product: ID
	property: Property
	productDetails: Component
}

type InstanceWithHistory {
