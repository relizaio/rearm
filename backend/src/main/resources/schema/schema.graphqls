	# KEV catalog sources (V54 per-org refactor). Must stay in sync with the
	# Java IntegrationType enum: enableKevSource/disableKevSource take these as
	# an input arg and configuredBaseIntegrations returns them as output, so a
	# missing value here breaks both coercion (enable/disable) and output
	# serialization (every org has a CISA_KEV row after the V54 backfill).
	CISA_KEV
	VULNCHECK_KEV
}

# Capabilities a GITHUB integration is wired up to perform. Picked at
# create/update time, validated by the server, and used both as a UI
# filter (e.g. the "create webhook" picker only shows integrations with
# WEBHOOK) and as a runtime guard on outbound dispatch paths.
enum IntegrationCapability {
	WORKFLOW_DISPATCH
	PR_VALIDATE
	WEBHOOK
}

# Inbound GitHub webhook receiver. The (org, slug) pair forms the public
# URL path /api/programmatic/v1/webhook/{org}/{slug}; delivery, signature
# verification and PR upsert key entirely on (org, slug) + the row's own
# secret. The integration link is OPTIONAL (null = standalone): it is an
# organizational association only (capability gate, one-to-one cardinality,
# integration delete-protection) and is never read on delivery.
# encryptedSecret is intentionally not exposed back through the API --
# it's set-only on create / update.
type Webhook {
	uuid: ID
	org: ID
	# Optional associated GITHUB+WEBHOOK integration; null for a standalone webhook.
	integration: ID
	slug: String
	note: String
	status: WebhookStatus
	lastDeliveryAt: DateTime
	lastDeliveryStatus: WebhookDeliveryOutcome
	lastDeliveryId: String
	consecutiveFailureCount: Int
	createdDate: DateTime
	updatedDate: DateTime
}

input WebhookInput {
	org: ID!
	# Optional. Associate with a GITHUB+WEBHOOK integration (organizational
	# link only). Omit/null for a standalone webhook -- delivery is identical.
	integration: ID
	# Lowercase ASCII, 4-63 chars, no leading/trailing hyphen. Unique
	# within the org. Reserved values are rejected.
	slug: String!
	# Plain HMAC-SHA256 key (matches the value pasted into the GitHub
	# App's "Webhook secret" field). Encrypted at rest.
	secret: String!
	# GitHub installation ID (numeric, passed as string for symmetry
	# with the GH App's existing schedule field).
	installation: String
	note: String
}

input WebhookUpdateInput {
	uuid: ID!
	note: String
	status: WebhookStatus
	# Pass empty string to clear, omit to preserve.
	installation: String
	# Optional association change (organizational link only, never affects
	# delivery): omit to preserve, empty string to clear (-> standalone),
	# or a GITHUB+WEBHOOK integration id to set/change it.
	integration: ID
	# Pass to rotate; omit to keep existing.
	secret: String
	# Pass to rename. Same regex + uniqueness rules as create. Changing
	# the slug also changes the public webhook URL -- re-register it on
	# the GitHub App side at the same time.
	slug: String
}

enum WebhookStatus {
	ACTIVE
	DISABLED
}

enum WebhookDeliveryOutcome {
	SUCCESS
	SIGNATURE_INVALID
	HANDLER_ERROR
	UNKNOWN_EVENT
	DUPLICATE
	WEBHOOK_DISABLED
}

enum BomFormat {
	CYCLONEDX
	SPDX
}

"""
Where an artifact's bytes are stored.
- REARM: bytes live in ReARM's blob store; downloadable in-place
  via /api/manual/v1/artifact/<uuid>/rawdownload.
- EXTERNALLY: only metadata + downloadLinks recorded; the UI must
  send the user to one of the registered downloadLinks instead.
"""
enum ArtifactStoredIn {
	REARM
	EXTERNALLY
}

