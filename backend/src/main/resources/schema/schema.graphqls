	targetBranchName: String
	defaultStatus: Status!
	fallbackToBase: FallbackToBase
}

enum FallbackToBase {
	ENABLED
	DISABLED
}

type EffectiveDependency {
	component: Component!
	branch: Branch!
	status: Status!
	source: DependencySource!
	sourcePattern: DependencyPattern
	release: ID
	releaseDetails: Release
	isFollowVersion: Boolean
}

enum DependencySource {
	MANUAL
	PATTERN
}

type ReleaseCollection {
	uuid: ID
	artifactComparison: ArtifactComparison
}

type ArtifactComparison {
	changelog: ArtifactChangelog
	comparedReleaseUuid: ID
}

type ArtifactChangelog {
	added : [DiffComponent]
	removed: [DiffComponent]
}

type DiffComponent {
	purl: String
	version: String
}

type Release {
	uuid: ID
	version: String
	marketingVersion: String
	status: Status
	lifecycle: ReleaseLifecycleEnum
	"""
	Computed (Distribution): true when this release's component is HARDWARE, or --
	for a product release -- when at least one constituent component release is.
	"""
	hardware: Boolean
	org: ID
	orgDetails: Organization
	component: ID
	componentDetails: Component
	branch: ID
	branchDetails: Branch
	parentReleases: [ParentRelease]
	sourceCodeEntry: ID
	sourceCodeEntryDetails: SourceCodeEntry
	commits: [ID]
	commitTime: DateTime
	commitsDetails: [SourceCodeEntry]
	"""
	Pull requests this release participates in -- any PR whose commits[]
	intersects this release's commits[]. Computed at read time; resolves
	by matching SCE UUIDs.
	"""
	pullRequests: [PullRequest]
	artifacts: [ID]
	artifactDetails: [Artifact]
	inboundDeliverables: [ID]
	inboundDeliverableDetails: [Deliverable]
	tickets: [ID]
	ticketDetails: [Ticket]
	notes: String
	decoratedVersionString: String
	createdType: ProgrammaticType
	lastUpdatedBy: ID
	createdDate: DateTime
	endpoint: String
	inProducts: [Release]
	vcsRepository: VcsRepository
	tags: [TagRecord]
	approvedEnvironments: [String]
	approvalEvents: [ReleaseApprovalEvent]
	approvalRequests: [ReleaseApprovalRequest]
	variantDetails: [Variant]
	updateEvents: [ReleaseUpdateEvent]
	metrics: DependencyTrackMetrics
	identifiers: [Identifier]
	gudidRecord: GudidRecord
	gudidStatus: GudidStatus
	eos: String
	eol: String
	"""
	Component name snapshot captured when a sid PURL was first emitted for this release (D6).
	Immutable once set. Null on releases pre-dating sid enablement and on releases of
	EXTERNAL components.
	"""
	sidComponentName: String
	"""
	Resolved BOM root identifier per the D4 picker: sid PURL > any other PURL >
	release UUID. Always non-null. Used by the UI to display the canonical
	identifier and matches what VDR / OBOM / aggregated-SBOM emit at the BOM root.
	"""
	preferredBomIdentifier: String
	releaseCollection: ReleaseCollection
	"""
	Adjacent releases on this release's own branch / feature set, ordered by
	created date (the same CANCELLED-excluding lineage used for the SBOM-component
	changelog). previousRelease is the release created immediately before this one
	on the branch, nextRelease the one immediately after; both are null at the
	branch's first / last release. Unlike the changelog baseline these do NOT fall
	back to a base-branch fork point -- navigation stays within the same branch.
	Lazily resolved: only queried when selected. Select a light subselection
	(e.g. uuid version lifecycle createdDate) -- used by the release view's
	prev/next navigation arrows.
	"""
	previousRelease: Release
	nextRelease: Release
	intermediateFailedReleases: [IntermediateFailedRelease]
	# True if the release has been queued for SBOM-component reconciliation
	# but the every-minute scheduler hasn't drained it yet. Use to surface a
	# "reconcile pending" indicator in the UI.
	sbomReconcilePending: Boolean
	"""
	Distinct AgentSessions whose commits contributed to this release.
	Walks release.commits -> SCE.agentSession (the forward pointer set
	by the PR 2 commit-trailer parser) and dedupes. Empty list when
	no commits carry agent attribution.
	"""
	sessions: [Session]
}

type IntermediateFailedRelease {
	releaseUuid: ID!
	releaseVersion: String!
	releaseLifecycle: ReleaseLifecycleEnum!
	releaseCreatedDate: DateTime
	commits: [SourceCodeEntry]
}

type Variant {
	uuid: ID
	identifier: String
	identifierPrefix: String
	order: Int
	version: String
	marketingVersion: String
	sku: String
	type: VariantType
	org: ID
	orgDetails: Organization
	release: ID
	outboundDeliverables: [ID]
	outboundDeliverableDetails: [Deliverable]
	notes: String
	endpoint: String
	tags: [TagRecord] 
}

type MarketingRelease {
	uuid: ID
	version: String
	status: Status
	org: ID
	orgDetails: Organization
	component: ID
	componentDetails: Component
	notes: String
	tags: [TagRecord]
	lifecycle: MarketingReleaseLifecycleEnum
	integrateType: IntegrateType
	integrateBranch: ID
	integrateBranchDetails: Branch
	devReleasePointer: ID
	lastUpdatedBy: ID
	createdDate: DateTime
	devReleaseDetails: Release
	events: [MarketingReleaseEvent]
}

type MarketingReleaseEvent {
	release: ID
	releaseDetails: Release
	lifecycle: MarketingReleaseLifecycleEnum
	date: DateTime
	wu: WhoUpdated
}

type WhoUpdated {
	createdType: ProgrammaticType
	lastUpdatedBy: String
}

type ParentRelease {
	org: ID
	release: ID
	releaseDetails: Release
}

type SourceCodeEntry {
	uuid: ID
	branch: ID
	vcsUuid: ID
	vcsBranch: String
	vcsRepository: VcsRepository
	commit: String
	commits: String
	commitMessage: String
	commitAuthor: String
	commitEmail: String
	vcsTag: String
	notes: String
	org: ID
	dateActual: DateTime
	createdType: ProgrammaticType
	lastUpdatedBy: ID
	createdDate: DateTime
	artifacts: [ID]
	artifactDetails: [Artifact]
	"""
	Resolved AgentSession this commit was authored under, or null on
	non-agent commits / unresolved trailers. Set by the PR 2
	commit-trailer parser from ReARM-Agentic-Session: on the commit
	message.
	"""
	agentSession: ID
	"""
	Leaf agent that authored the commit (may be a SUB; the session's
	{@code agent} is always the ROOT). Set by the PR 2 commit-trailer
	parser from ReARM-Agent: on the commit message.
	"""
	agent: ID
	"""
	Releases whose primary SCE is this commit. Typically 0 or 1, but
	rebuilds against the same commit produce multiple entries. Each
	release is the natural place the UI can jump to from a commit row.
	"""
	releases: [Release]
	"""
	Latest signature-verification verdict for this commit (or null when
	no signature artifact has been attached). Backed by the
	signature_verifications row pointed at by this SCE -- read-time
	pick of the most-recent verdict for (SCE, subjectUuid). Used by
	CEL via {@code commit.signature.*}.
	"""
	signature: SceSignature
	"""
	Outcome of the agent-attribution trailer resolution for this commit.
	UNATTRIBUTED on non-agent commits; RESOLVED when both trailers parsed
	and the agent / session were found; REJECTED when the trailers were
	present but the claim could not be resolved (malformed clientSessionId,
	unknown agent / session, cross-org, etc.). Used by CEL via
	{@code commit.attribution.state} -- symmetric with
	{@code commit.signature.state} for the unsigned-commit gate.
	"""
	attributionState: AttributionState
	"""
	Human-readable reason explaining a REJECTED attribution. Null on
	UNATTRIBUTED and RESOLVED.
	"""
	attributionReason: String
}

enum AttributionState {
	UNATTRIBUTED
	RESOLVED
	REJECTED
}

type DigestRecord{
	algo: TeaArtifactChecksumType
	digest: String
	scope: DigestScope
}

type Artifact {
	uuid: ID
	displayIdentifier: String
	"""
	Whether the artifact bytes live inside ReARM's blob store (REARM)
	or only as external download links (EXTERNALLY). UI uses this to
	decide whether to render an in-place download button.
	"""
	storedIn: ArtifactStoredIn
	org: ID
	branch: ID
	buildId: String
	buildUri: String
	cicdMeta: String
	digestRecords: [DigestRecord]
	isInternal: ArtifactBelonging
	type: ArtifactType
	bomFormat: BomFormat
	specVersion: SpecVersion
	serializationFormat: SerializationFormat
	notes: String
	tags: [TagRecord]
	tagRecords: [TagRecord]
	dateFrom: DateTime
	dateTo: DateTime
	duration: Long
	packageType: PackageType
	version: String
	publisher: String
	group: String
	dependencies: [ID]
	createdType: ProgrammaticType
	lastUpdatedBy: ID
	createdDate: DateTime
	internalBom: InternalBom
	downloadLinks: [Downloadlink]
	metrics: DependencyTrackMetrics
	componentUuid: ID
	artifacts: [ID]
	artifactDetails: [Artifact]
	# Rebom-side enrichment status for this artifact's BOM. Null for artifacts
	# without an internalBom (non-BOM types, or BOMs that failed to land in
	# rebom). The UI uses this to render PENDING / COMPLETED / FAILED / SKIPPED
	# pills next to the artifact row.
	enrichmentStatus: EnrichmentStatus
	# Outcome of the VEX import this artifact triggered (VEX artifacts only;
	# null otherwise). Lets the UI report matched / unmatched statement counts
	# instead of leaving the user with a silently empty VEX tab.
	vexImportSummary: VexImportSummary
}

# Counts from a single VEX import, persisted on the VEX artifact that produced
# it. proposalsCreated = statements staged for review (PENDING);
# proposalsAutoAccepted = statements applied immediately; statementsUnmatched =
# statements whose product did not match any component in the release's SBOM
# inventory (these produce no proposal).
type VexImportSummary {
	statementsTotal: Int
	proposalsCreated: Int
	proposalsAutoAccepted: Int
	proposalsAutoRejected: Int
	statementsUnmatched: Int
	statementsErrored: Int
	errorMessages: [String]
}

enum EnrichmentStatus {
	PENDING
	COMPLETED
	FAILED
	SKIPPED
}

type ImportComponentResult {
	componentName: String
	version: String
	success: Boolean
	error: String
}

