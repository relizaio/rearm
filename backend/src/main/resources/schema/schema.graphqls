# ========== Sealed Interface Changelog Types ==========

union ComponentChangelog = NoneChangelog | AggregatedChangelog

type NoneChangelog {
	componentUuid: ID!
	componentName: String!
	orgUuid: ID!
	firstRelease: ReleaseInfo!
	lastRelease: ReleaseInfo!
