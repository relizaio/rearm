type Query {
	user: User
	organizations: [Organization]
	adminOrganization(org: ID!): AdminOrganization
	allOrganizations: [Organization]
	
	# changelog (sealed interface API)
	componentChangelog(release1:ID!, release2:ID!, orgUuid:ID!, aggregated: AggregationType!, timeZone: String): ComponentChangelog
	componentChangelogByDate(componentUuid:ID!, branchUuid:ID, orgUuid:ID!, aggregated: AggregationType!, timeZone: String, dateFrom: DateTime!, dateTo: DateTime!): ComponentChangelog
	organizationChangelogByDate(orgUuid: ID!, perspectiveUuid: ID, dateFrom: DateTime!, dateTo: DateTime!, aggregated: AggregationType!, timeZone: String): OrganizationChangelog
	
	releaseTagKeys(orgUuid: ID!): [String]
	component(componentUuid:ID!): Component
	components(orgUuid:ID!, componentType:ComponentType!, perspective:ID): [Component]
	branch(branchUuid:ID!): Branch
	branchesOfComponent(componentUuid:ID!): [Branch]
	releases(branchFilter:ID, orgFilter:ID, releaseFilter:[ID], numRecords:Int): [Release]
	getNextVersion(branchUuid:ID!, versionType: VersionType): String
	vcsRepository(vcs:ID!): VcsRepository
	listVcsReposOfOrganization(orgUuid:ID!): [VcsRepository]
	pullRequest(prUuid: ID!): PullRequest
	"""
	List PullRequests for an org. {@code states} narrows the result to
	the supplied {@link PullRequestState} values (case-insensitive); pass
	null/empty to fetch every state. The UI defaults to {@code [OPEN]}
	so terminal-state PRs aren't loaded until the user opts in via the
	state filter.
	"""
	pullRequestsOfOrg(orgUuid: ID!, states: [String!]): [PullRequest]
	"""
	List PullRequests targeting a given VCS repository. {@code states}
	narrows the result by {@link PullRequestState}; pass null/empty for
	all states. Mirrors the {@code pullRequestsOfOrg} default of {@code
	[OPEN]} on the UI side.
	"""
	pullRequestsOfVcs(vcs: ID!, states: [String!]): [PullRequest]
	vcsRepositoryTypes: [String]
	sourceCodeEntry(sceUuid:ID!): SourceCodeEntry
	artifact(artifactUuid: ID!): Artifact
	artifactVersionHistory(artifactUuid: ID!): [Artifact]
	artifactTypes: [String]
	release(releaseUuid: ID!, orgUuid: ID): Release
	users(orgUuid: ID!, includeInactive: Boolean): [OrgUserData]
	combinedUserOrgPermissions(orgUuid: ID!, userUuid: ID!): Permissions
	resourceGroups(orgUuid: ID!): [ResourceGroup]
	releaseAnalytics(orgUuid: ID!, cutOffDate: DateTime!): [VegaDateValue]
	releaseAnalyticsByComponent(componentUuid: ID!, cutOffDate: DateTime!): [VegaDateValue]
	releaseAnalyticsByBranch(branchUuid: ID!, cutOffDate: DateTime!): [VegaDateValue]
	releaseAnalyticsByPerspective(perspectiveUuid: ID!, cutOffDate: DateTime!): [VegaDateValue]
	totalsAnalytics(orgUuid: ID!): Object
	apiKeys(orgUuid: ID!): [ApiKey]
	marketingRelease(marketingReleaseUuid: ID!): MarketingRelease
	marketingReleases(componentUuid: ID!): [MarketingRelease]
	marketingReleaseLifecycles: [MarketingReleaseLifecycle]
	defaultApprovalRoles: [ApprovalRole]
	approvalPoliciesOfOrg(orgUuid: ID!): [ApprovalPolicy]
	approvalEntriesOfOrg(orgUuid: ID!): [ApprovalEntry]
	artifactReleases(artUuid: ID!): [Release]
	artifactBomLatestVersion(artUuid: ID!): String
	# Deliverables
	deliverable(deliverable: ID!): Deliverable
	listDeliverablesByComponent(componentUuid: ID!): [Deliverable]
	
	# Artifact Collections
	getAcollectionsOfRelease(releaseUuid: ID!): [AcollectionData]

	# Detailed SBOM components aggregated across all BOM artifacts of a release.
	# Each entry is keyed by the canonical purl (purl with qualifiers stripped);
	# artifactParticipations carries the list of artifacts that referenced this
	# component and the exact (qualifier-carrying) purls each one used.
	getReleaseSbomComponents(releaseUuid: ID!): [ReleaseSbomComponent]

	# Single-component graph view: the merged ReleaseSbomComponent row for
	# (release, canonical sbom component), with the same dependencies /
	# dependedOnBy resolvers as getReleaseSbomComponents. Returns null when
	# the canonical component does not appear in the release (or its dep tree,
	# for product releases). Use this from a graph-detail page to navigate by
	# stable (releaseUuid, sbomComponentUuid) instead of scanning the full
	# release set client-side.
	getReleaseSbomComponentGraph(releaseUuid: ID!, sbomComponentUuid: ID!): ReleaseSbomComponent

	configuredBaseIntegrations(org: ID!): [IntegrationType]
	ciIntegrations(org: ID!): [CiIntegration]

	# Inbound webhook reception. {org}/{slug} forms the public URL path
	# the GitHub App is configured to POST to.
	webhook(uuid: ID!): Webhook
	webhooks(orgUuid: ID!): [Webhook]
	
	# Analytics
	mostActiveComponentsOverTime(activeComponentsInput: ActiveComponentsInput!): [ReleasesPerComponent]
	mostActiveBranchesOverTime(activeComponentsInput: ActiveComponentsInput!): [ReleasesPerBranch]
	mostActiveComponentsOverTimeByPerspective(activeComponentsInput: ActiveComponentsInput!, perspectiveUuid: ID!): [ReleasesPerComponent]
	mostActiveBranchesOverTimeByPerspective(activeComponentsInput: ActiveComponentsInput!, perspectiveUuid: ID!): [ReleasesPerBranch]
	vulnerabilitiesViolationsOverTime(orgUuid: ID!, dateFrom: DateTime!, dateTo: DateTime!): [VulnerabilityViolationChart]
	vulnerabilitiesViolationsOverTimeByComponent(componentUuid: ID!, dateFrom: DateTime!, dateTo: DateTime!): [VulnerabilityViolationChart]
	vulnerabilitiesViolationsOverTimeByBranch(branchUuid: ID!, dateFrom: DateTime!, dateTo: DateTime!): [VulnerabilityViolationChart]
	vulnerabilitiesViolationsOverTimeByPerspective(perspectiveUuid: ID!, dateFrom: DateTime!, dateTo: DateTime!): [VulnerabilityViolationChart]
	mostVulnerableComponentsPerOrg(orgUuid: ID!, createdDate: DateTime!, componentType: ComponentType!, maxComponents: Int!, perspectiveUuid: ID): [MostVulnerableComponent]
	findingsPerDay(orgUuid: ID!, date: String!): DependencyTrackMetrics
	findingsPerDayForComponent(componentUuid: ID!, date: String!): DependencyTrackMetrics
	findingsPerDayForBranch(branchUuid: ID!, date: String!): DependencyTrackMetrics
	findingsPerDayByPerspective(perspectiveUuid: ID!, date: String!): DependencyTrackMetrics
	
	# Programmatic
	getSbomProbingResult(runId: String!): SbomProbingResult
	getReleaseByHashProgrammatic(hash: String!, componentId: ID): String
	getReleaseByReleaseVersionProgrammatic(version: String!, componentId: ID!): String
	getLatestReleaseProgrammaticCdx(release: GetLatestReleaseInput!): String
	getLatestReleaseProgrammatic(release: GetLatestReleaseInput!): Release
	
	organization(orgUuid: ID!): Organization
	
	healthCheck: String
	searchDigestVersion(orgUuid: ID!, query: String!, perspectiveUuid: ID): SearchDigestVersionResponse
	releasesByTags(orgUuid: ID!, branchUuid: ID, tagKey: String!, tagValue:String, perspectiveUuid: ID): [Release]
	releasesByDtrackProjects(orgUuid: ID!, dtrackProjects: [ID], perspectiveUuid: ID): [ComponentWithBranches]
	sbomComponentSearch(orgUuid: ID!, queries: [SbomComponentSearchInput!]!, perspectiveUuid: ID): [ComponentPurlToDtrack]
	searchDtrackComponentByPurlAndProjects(orgUuid: ID!, purl: String!, dtrackProjects: [ID]!): ID

	# Native (non-DependencyTrack) SBOM-component analogues of the three queries
	# above. Search and grouping run against rearm.sbom_components /
	# rearm.release_sbom_components instead of dtrack — same shapes, sbom_component
	# UUIDs in place of dtrack project UUIDs. See SbomComponentDataFetcher.
	releasesBySbomComponents(orgUuid: ID!, sbomComponentUuids: [ID]!, perspectiveUuid: ID): [ComponentWithBranches]
	sbomComponentSearchNative(orgUuid: ID!, queries: [SbomComponentSearchInput!]!, perspectiveUuid: ID): [ComponentPurlToSbom]
	searchSbomComponentByPurl(orgUuid: ID!, purl: String!): ID
	
	getAllOrganizations: [Organization]
	
	getSystemInfoIsSet: SystemInfoIsSet
	license: LicensePayload
	
	exportAsObomManual(releaseUuid: ID!): String

	"""
	Export a CLE-spec-valid JSON document for a component (or product).
	The events array is the same chronological union the TEA endpoint
	returns; this query wraps it with the spec-required `$schema` and
	`lastUpdated` metadata so the response stands alone as a CLE document.
	"""
	exportComponentCleManual(componentUuid: ID!): String

	"""
	Export a CLE-spec-valid JSON document for a single release. Mirrors
	exportComponentCleManual at the release level — events come from
	transformReleaseToCle.
	"""
	exportReleaseCleManual(releaseUuid: ID!): String
	
	# User Groups
	getUserGroups(org: ID!): [UserGroupWebDto]
	
	# Vulnerability Analysis
	getVulnAnalysis(org: ID!): [VulnAnalysisWebDto]
	getVulnAnalysisByComponent(componentUuid: ID!): [VulnAnalysisWebDto]
	getVulnAnalysisByBranch(branchUuid: ID!): [VulnAnalysisWebDto]
	getVulnAnalysisByRelease(releaseUuid: ID!): [VulnAnalysisWebDto]
	getVulnAnalysisByLocationAndFinding(org: ID!, location: String!, findingId: String!, findingType: FindingType!): [VulnAnalysisWebDto]
	getVulnAnalysisByPerspective(perspectiveUuid: ID!): [VulnAnalysisWebDto]
	getVexStatementProposals(org: ID!, status: ProposalStatus): [VexStatementProposalWebDto]
	getVexStatementProposal(uuid: ID!): VexStatementProposalWebDto
	getVexStatementProposalsBySourceArtifact(artifact: ID!): [VexStatementProposalWebDto]
	getVexStatementProposalsByRelease(org: ID!, release: ID!): [VexStatementProposalWebDto]
	getMitigationAttestations(org: ID!, status: AttestationStatus): [MitigationAttestationWebDto]
	getMitigationAttestation(uuid: ID!): MitigationAttestationWebDto
	getMitigationAttestationsByAssignee(assignee: ID!, status: AttestationStatus): [MitigationAttestationWebDto]

	# Perspectives
	perspectives(org: ID!): [Perspective]
	componentsOfPerspective(perspectiveUuid: ID!): [Component]

	# Download Logs
	listDownloadLogs(org: ID!, fromDate: DateTime, toDate: DateTime, perspective: ID): [DownloadLog]
	
	# CVE Search
	searchReleasesByCveId(org: ID!, cveId: String!, perspectiveUuid: ID): [ComponentWithBranches]
	# Time Frame Search
	searchReleasesByTimeFrame(org: ID!, startDate: DateTime!, endDate: DateTime!, perspectiveUuid: ID): [ComponentWithBranches]
	searchReleasesByTimeFrameAndComponent(componentUuid: ID!, startDate: DateTime!, endDate: DateTime!): [ComponentWithBranches]
	searchReleasesByTimeFrameAndBranch(branchUuid: ID!, startDate: DateTime!, endDate: DateTime!): [ComponentWithBranches]
	# Date Range Queries - return flat [Release] list
	releasesByDateRange(org: ID!, startDate: DateTime!, endDate: DateTime!, limit: Int, componentType: ComponentType): [Release]
	releasesByDateRangeAndComponent(componentUuid: ID!, startDate: DateTime!, endDate: DateTime!, limit: Int): [Release]
	releasesByDateRangeAndBranch(branchUuid: ID!, startDate: DateTime!, endDate: DateTime!, limit: Int): [Release]
	releasesByDateRangeAndPerspective(perspectiveUuid: ID!, startDate: DateTime!, endDate: DateTime!, limit: Int, componentType: ComponentType): [Release]
	# Pattern Preview
	previewPattern(orgUuid: ID!, pattern: String!, targetBranchName: String, defaultStatus: Status, fallbackToBase: FallbackToBase): [EffectiveDependency]

	# Reverse dependency lookup: which feature sets include this component/branch as a dependency
	# (any requirement type — REQUIRED, OPTIONAL, or IGNORED — via explicit deps or patterns)
	featureSetsUsingComponent(componentUuid: ID!): [Branch]
	featureSetsUsingBranch(branchUuid: ID!): [Branch]

	# Instances
	instance(instanceUuid: ID!, revision: Int): Instance
	instancesOfOrganization(orgUuid: ID!): [Instance]
	instancesByProp(orgUuid: ID!, propKey: ID, propVal: String!): [Instance]
	instanceHistoryPlan(instanceUuid: ID!): [InstanceHistoryPlan]
	instanceHistoryActual(instanceUuid: ID!): [InstanceHistoryActual]
	instanceHistoryPlanByDate(instanceUuid: ID!, fromDate: DateTime!, toDate: DateTime!, changeType: InstancePlanChangeType): [InstanceHistoryPlan]
	instanceHistoryActualByDate(instanceUuid: ID!, fromDate: DateTime!, toDate: DateTime!, changeType: InstanceActualChangeType): [InstanceHistoryActual]
	searchChangesOverTime(orgUuid: ID!, fromDate: DateTime!, toDate: DateTime!): [InstanceWithHistory]
	environmentTypes(orgUuid: ID, includeBuiltIn: Boolean): [String]
	getInstanceRevisionCycloneDxExportManual(instanceUuid: ID!, revision: Int, namespace: String, stateType: InstanceStateType): String
	getInstanceRevisionCycloneDxExportProg(instanceUuid: ID, instanceUri: String, revision: Int!, namespace: String, stateType: InstanceStateType): String
	isInstanceHasSealedSecretCert(instanceUuid: ID, instanceUri: String): Boolean
	getInstancePropSecrets(instanceUuid: ID, instanceUri: String, namespace: String!, revision: Int!, properties: [String], secrets: [String], product: ID, productSpecificProps: Boolean): PropSecrets
	deliverableDownloadSecrets(instanceUuid: ID, instanceUri: String, deliverableDigest: String!, namespace: String, releaseNs: String): ComponentAuthentication
	# Per-product feature-set inventory of an instance plan, scoped to a
	# namespace. FREEFORM-only; requires DEVOPS_READ on the instance (or
	# its parent cluster). namespace is required for STANDALONE_INSTANCE
	# and CLUSTER instances; for CLUSTER_INSTANCE it is pinned to the
	# instance's own namespace and any value passed is ignored. Pass
	# either instanceUuid or instanceUri (looked up against the FREEFORM
	# key's org) to identify the instance.
	listInstanceProductFeatureSets(instanceUuid: ID, instanceUri: String, namespace: String): [InstanceProductFeatureSets!]!

	# properties
	property(propertyUuid: ID!): Property
	propertyDataTypes: [PropertyDataType]
	propertyConfigTypes: [PropertyConfigurableType]
	propertiesOfOrg(orgUuid: ID!): [Property]

	# secrets
	secret(secretUuid:ID!, orgUuid:ID!): Secret
	secrets(orgUuid:ID!): [Secret]
	
	# BEAR integration
	getBearIntegration(org: ID!): BearIntegration
}

type Mutation {
	# user management
	acceptUserPolicies(tosAccepted: Boolean!, marketingAccepted: Boolean!, email: String): User
	verifyEmail(secret: String!): User
	inviteUser(invitationProperties: InviteUserInput!): AdminOrganization
	joinUserToOrganization(secret: String!): User
	cancelInvite(org: ID!, userEmail: String!): AdminOrganization
	updateUserPermissions(orgUuid: ID!, userUuid: ID!, permissionType: PermissionType, permissions: [PermissionInput]): OrgUserData
	updateUserName(name: String!): User
		
	# system global
	unSealSystem(secret: String): Boolean
	uploadLicense(license: String!): LicensePayload
	finalizeAllReleases: Boolean
	createOrganization(name: String!): Organization
	setEmailProperties(emailProperties: EmailPropertiesInput!): Boolean
	setDefaultOrganization(organization: ID!): Boolean
	inactivateUser(userUuid: ID!): User
	reactivateUser(userUuid: ID!): User
	sendTestEmail: Boolean
	
	# integrations
	createIntegration(integration: IntegrationInput!): Integration
	createTriggerIntegration(integration: IntegrationInput!): Integration
	deleteBaseIntegration(org: ID!, type: IntegrationType!): Boolean
	# Replace the capabilities asserted on an Integration. Org-admin
	# authorized; idempotent; preserves all other fields.
	updateIntegrationCapabilities(uuid: ID!, capabilities: [IntegrationCapability!]!): Integration

	# webhooks (inbound)
	createWebhook(webhook: WebhookInput!): Webhook
	updateWebhook(webhook: WebhookUpdateInput!): Webhook
	deleteWebhook(uuid: ID!): Boolean
	refetchDependencyTrackMetrics(artifact: ID!): Boolean
	requestRefreshDependencyTrackMetrics(artifact: ID!): Boolean
	syncDtrackStatus(orgUuid: ID!): SyncDtrackStatusResponse
	
	# cdx import
	importCyclonedxComponents(orgUuid: ID!, cdxJson: String!): [ImportComponentResult]
	
	# components and products
	createComponent(component: CreateComponentInput!): Component
	updateComponent(component: UpdateComponentInput!): Component
	createBranch(componentUuid: ID!, name: String!, versionSchema: String): Branch
	updateBranch(branch: BranchInput!): Branch
	autoIntegrateFeatureSet(branchUuid: ID!): Release
	archiveBranch(branchUuid: ID!): Boolean
	archiveComponent(componentUuid: ID!): Boolean
	setNextVersion(branchUuid: ID!, versionString: String!, versionType: VersionType): Boolean
	"""
	Iterates active releases of the component and fills in identifiers for any that
	currently have an empty identifier list. Releases that already carry any identifier
	(PURL, CPE, TEI, etc.) are left untouched — this mutation is intentionally narrow
	per design D13 / D15: v1 does not productize a "rebuild sid PURL on existing releases"
	flow. Operators wanting to migrate sid identity on already-identified releases must
	use a one-off script.
	"""
	updateComponentReleasesIdentifiers(componentUuid: ID!): Boolean
	
	createVcsRepository(vcsRepository: VcsRepositoryInput!): VcsRepository
	updateVcsRepository(vcsUuid: ID!, name: String, uri: String): VcsRepository
	"""
	Replace the VCS repository's output triggers. Constraint: at most one
	entry, and (if present) must be of type EXTERNAL_VALIDATION. Pass an
	empty list to clear.
	"""
	setVcsRepositoryOutputTriggers(vcsUuid: ID!, triggers: [ReleaseOutputEventInput!]!): VcsRepository
	"""
	Replace the org's global PR-validation trigger rules atomically.
	Each input rule must (a) carry a non-blank, org-unique {@code name},
	(b) compile as a valid Java regex, (c) supply a trigger of type
	EXTERNAL_VALIDATION whose {@code integration} resolves to a GITHUB
	integration in the same org with the PR_VALIDATE capability. Pass
	an empty list to clear all rules. SAAS-only — the SAAS DataFetcher
	guards on installation type. List order is the priority order;
	send the rules in the order you want first-match-wins to honour.
	"""
	setGlobalPrValidationTriggerRules(orgUuid: ID!, rules: [GlobalPrValidationTriggerRuleInput!]!): Organization
	"""
	Replace the org's global approval-policy assignment rules
	atomically. Each input rule must (a) carry a non-blank, org-unique
	{@code name}, (b) compile as a valid Java regex in
	{@code namePattern}, (c) supply an {@code approvalPolicy} UUID
	that resolves to an existing policy in the same org. Pass an empty
	list to clear all rules. SAAS-only — the SAAS DataFetcher guards on
	installation type. List order is the priority order; send the
	rules in the order you want first-match-wins to honour.
	"""
	setGlobalApprovalPolicyRules(orgUuid: ID!, rules: [GlobalApprovalPolicyRuleInput!]!): Organization
	"""
	Programmatic (API-key) upsert of a PullRequest. CI registers the PR
	row independently of release creation so the registration survives
	push/pull_request races and DO_BUILD=false short-circuits.
	Idempotent on (targetVcsRepository, identity) — safe to call
	multiple times per CI run (e.g. once per component in a monorepo).
	When `commit` is supplied and an SCE already exists for
	(targetVcs, commit), the head is advanced to that SCE in the same
	call; otherwise the PR row is registered without a head and the
	subsequent addReleaseProgrammatic call (which carries the same PR
	input) will advance the head once the SCE is persisted.
	Resolves the target VCS by `vcsUri`+`repoPath` (FREEFORM or
	ORGANIZATION_RW key) or by `component` UUID (COMPONENT,
	FREEFORM, or ORGANIZATION_RW key). Accepts COMPONENT, FREEFORM,
	or ORGANIZATION_RW API keys; other ORGANIZATION_* types are
	rejected.
	"""
	upsertPullRequestProgrammatic(input: PullRequestUpsertProgrammaticInput!): PullRequest
	archiveVcsRepository(vcsUuid: ID!): Boolean
	getNewVersionManual(branchUuid: ID!, action: ActionEnum): Version
	createSourceCodeEntry(sourceCodeEntry: SourceCodeEntryInput!): SourceCodeEntry
	addReleaseManual(release: ReleaseInput!): Release
	setComponentApiKey(componentUuid: ID!): ApiKeyForUser
	setOrgApiKey(orgUuid: ID!, apiType: ApiTypeEnum!, keyOrder: String, notes: String): ApiKeyForUser
	updateRelease(release: ReleaseInput!): Release
	updateReleaseLifecycle(release: ID!, newLifecycle: ReleaseLifecycleEnum!): Release

	"""
	Bulk-advance every release of a component whose lifecycle is
	≥ GENERAL_AVAILABILITY but < `targetLifecycle` to `targetLifecycle`.
	Pre-GA releases (PENDING, DRAFT, ASSEMBLED, READY_TO_SHIP) and
	terminal-state releases (CANCELLED, REJECTED) are untouched, as are
	releases already at or beyond the target. Each bumped release records
	a normal LIFECYCLE-CHANGED update event so per-release histories stay
	coherent and the CLE synthesis surfaces the bump as a merged
	component-level event by minute. `targetLifecycle` must be > GA
	(ordinal-bounded so the validation survives future enum additions);
	GA itself isn't a meaningful bulk target — that's the natural state
	for assembled releases.
	"""
	bulkUpdateComponentReleaseLifecycle(componentUuid: ID!, targetLifecycle: ReleaseLifecycleEnum!): BulkLifecycleUpdateResult
	updateReleaseTagsMeta(release: ReleaseInput!): Release
	overrideApprovedEnvironments(releaseUuid: ID!, approvedEnvironments: [String!]!): Release
	addMarketingReleaseManual(marketingRelease: MarketingReleaseInput!): MarketingRelease
	updateMarketingRelease(marketingRelease: MarketingReleaseInput!): MarketingRelease
	modifyMarketingReleaseLifecycle(marketingReleaseUuid: ID!, newLifecycle: MarketingReleaseLifecycleEnum): MarketingRelease 
	archiveMarketingRelease(marketingReleaseUuid: ID!): Boolean
	releaseMarketingRelease(marketingRelease: MarketingReleaseInput!, marketingVersion: String!): MarketingRelease
	addApprovalRole(orgUuid: ID!, approvalRole: ApprovalRoleInput!): Organization
	deleteApprovalRole(orgUuid: ID!, approvalRoleId: String!): Organization
	updateOrganizationTerminology(orgUuid: ID!, terminology: TerminologyInput!): Organization
	updateOrganizationIgnoreViolation(orgUuid: ID!, ignoreViolation: IgnoreViolationInput!): Organization
	updateOrganizationSettings(orgUuid: ID!, settings: SettingsInput!): Organization
	createApprovalEntry(approvalEntry: ApprovalEntryInput!): ApprovalEntry
	archiveApprovalEntry(approvalEntryUuid: ID!): ApprovalEntry
	createApprovalPolicy(approvalPolicy: ApprovalPolicyInput!): ApprovalPolicy
	archiveApprovalPolicy(approvalPolicyUuid: ID!): ApprovalPolicy
	setGlobalInputEvents(approvalPolicyUuid: ID!, events: [ReleaseInputEventInput!]!): ApprovalPolicy
	setGlobalOutputEvents(approvalPolicyUuid: ID!, events: [ReleaseOutputEventInput!]!): ApprovalPolicy
	
	approveReleaseManual(release: ID!, approvals: [ReleaseApprovalInput!]): Release
	
	# Analytics
	computeAnalyticsMetricsForDate(orgUuid: ID!, date: String!): DependencyTrackMetrics
	
	updateArtifactTags(artifact: ID!, tags: [TagRecordInput]!): Artifact
	addArtifactManual(artifactInput: CreateArtifactInput, artifactUuid: ID): Release

	addOutboundDeliverablesManual(deliverables: AddDeliverableInput!): Boolean
	releaseSbomExport(release: ID!, tldOnly: Boolean, ignoreDev: Boolean, structure: BomStructureType, belongsTo: ArtifactBelongsToEnum, mediaType: BomMediaType, excludeCoverageTypes: [ArtifactCoverageType]): String
	releaseVdrExport(release: ID!, includeSuppressed: Boolean, upToDate: DateTime, targetLifecycle: ReleaseLifecycleEnum): String
	releaseVdrExportWithApproval(release: ID!, includeSuppressed: Boolean, upToDate: DateTime, targetLifecycle: ReleaseLifecycleEnum, targetApproval: String): String
	"""
	Generate a CycloneDX 1.6 VEX (Vulnerability Exploitability eXchange) document for a release.
	Filters vulnerabilities[] to decided analysis statements (EXPLOITABLE, NOT_AFFECTED, RESOLVED, FALSE_POSITIVE);
	IN_TRIAGE and analysis-less entries are excluded unless includeInTriage=true, in which case they are
	stamped with an explicit IN_TRIAGE analysis state. components[] is retained so the document is
	self-contained. Marked with VEX_DOCUMENT=true in metadata.properties. CE-compatible: supports DATE
	and LIFECYCLE snapshots.
	"""
	releaseCdxVexExport(release: ID!, includeSuppressed: Boolean, includeInTriage: Boolean, upToDate: DateTime, targetLifecycle: ReleaseLifecycleEnum): String
	"""
	SaaS-only. Generate a CycloneDX 1.6 VEX document with approval-snapshot support.
	Precedence: targetLifecycle > targetApproval > upToDate. Same filtering and metadata contract
	as releaseCdxVexExport.
	"""
	releaseCdxVexExportWithApproval(release: ID!, includeSuppressed: Boolean, includeInTriage: Boolean, upToDate: DateTime, targetLifecycle: ReleaseLifecycleEnum, targetApproval: String): String
	"""
	Generate an OpenVEX 0.2.0 document for a release. Reuses the same enrichment + snapshot +
	filtering pipeline as releaseCdxVexExport; each retained vulnerability is emitted as one
	OpenVEX statement. Status mapping: EXPLOITABLE→affected, NOT_AFFECTED→not_affected,
	FALSE_POSITIVE→not_affected (+ justification vulnerable_code_not_present), RESOLVED→fixed,
	IN_TRIAGE→under_investigation. CE-compatible: supports DATE and LIFECYCLE snapshots.
	"""
	releaseOpenVexExport(release: ID!, includeSuppressed: Boolean, includeInTriage: Boolean, upToDate: DateTime, targetLifecycle: ReleaseLifecycleEnum): String
	"""
	SaaS-only. Generate an OpenVEX 0.2.0 document with approval-snapshot support.
	Precedence: targetLifecycle > targetApproval > upToDate. Same status-mapping contract as
	releaseOpenVexExport.
	"""
	releaseOpenVexExportWithApproval(release: ID!, includeSuppressed: Boolean, includeInTriage: Boolean, upToDate: DateTime, targetLifecycle: ReleaseLifecycleEnum, targetApproval: String): String

	createFeatureSetFromRelease(featureSetName: String!, releaseUuid: ID!): Branch

	# Synchronously rebuild the SBOM component / dependency aggregation for a single release.
	# Operator escape hatch when a release is left with stale or empty release_sbom_components rows
	# (e.g. an earlier async reconcile failed). Returns true on success; throws on failure so the
	# caller sees the underlying error.
	reconcileReleaseSbomComponents(releaseUuid: ID!): Boolean

	# Programmatic
	setApprovalsOnApiKey(apiKeyUuid: ID!, approvals: [String], notes: String): ApiKey
	setPermissionsOnFreeformApiKey(apiKeyUuid: ID!, permissionType: PermissionType, permissions: [PermissionInput]): ApiKey
	"""
	Edit just the notes field on an API key. Admin auth on the owning
	org — paired with setPermissionsOnFreeformApiKey so a notes-only
	UI tab doesn't have to round-trip the full permissions list. Notes
	is a generic field on the api_keys recordData jsonb, so works for
	any key type (FREEFORM is the primary consumer today).
	"""
	setNotesOnApiKey(apiKeyUuid: ID!, notes: String): ApiKey
	deleteApiKey(apiKeyUuid: ID!): Boolean
	getNewVersionProgrammatic(newVersionInput: GetNewVersionInput!): Version
	addReleaseProgrammatic(release: ReleaseInputProg!): Release
	addOutboundDeliverablesProgrammatic(deliverables: AddODeliverableInput!): Release
	createComponentProgrammatic(component: CreateComponentInput!): Component
	"""
	Programmatic counterpart to createComponentInPerspective. Requires a FREEFORM API key
	with WRITE permission on the supplied perspective (or a broader scope that covers it).
	Only real perspectives (PerspectiveType.PERSPECTIVE) are accepted — product-derived
	perspectives are rejected.
	"""
	createComponentInPerspectiveProgrammatic(component: CreateComponentInput!, perspectiveUuid: ID!): Component
	addArtifactProgrammatic(artifactInput: AddArtifactInput): Release
	approveReleaseProgrammatic(releaseApprovals: ReleaseApprovalProgrammaticInput!): Release
	synchronizeLiveBranches(synchronizeBranchInput: SynchronizeBranchInput!): Boolean
	probeSbomProgrammatic(sbom: String!, componentUuid: ID, branchUuid: ID): SbomProbingRun
	releasecompletionfinalizerProgrammatic(release: ID!): Boolean
	triggerReleasecompletionfinalizer(release: ID!): Boolean
	removeUser(org: ID!, user: ID!): Boolean


	archiveOrganization(orgUuid: ID!): Boolean
	
	createResourceGroup(orgUuid: ID!, name: String!): ResourceGroup

	acceptPolicies(acceptTos: Boolean!, acceptMarketing: Boolean!, email: String): User
	logout: Boolean
	updateEmailAddress(oldEmail: String!, newEmail: String!, makePrimary: Boolean!, acceptMarketing: Boolean!): Boolean
	resendEmailVerification: Boolean
	
	# User Groups
	createUserGroup(userGroup: CreateUserGroupInput!): UserGroupWebDto
	updateUserGroup(userGroup: UpdateUserGroupInput!): UserGroupWebDto
	
	# Vulnerability Analysis
	createVulnAnalysis(analysis: CreateVulnAnalysisInput!): VulnAnalysisWebDto
	updateVulnAnalysis(analysis: UpdateVulnAnalysisInput!): VulnAnalysisWebDto
	acceptVexStatementProposal(uuid: ID!, comment: String): VexStatementProposalWebDto
	rejectVexStatementProposal(uuid: ID!, reason: String): VexStatementProposalWebDto
	updateVexStatementProposal(uuid: ID!, updates: VexProposalUpdateInput!): VexStatementProposalWebDto
	attestMitigation(uuid: ID!, evidence: String!): MitigationAttestationWebDto
	waiveMitigation(uuid: ID!, reason: String!): MitigationAttestationWebDto

	# Perspectives
	createPerspective(org: ID!, name: String!): Perspective
	updatePerspective(uuid: ID!, name: String!): Perspective
	"""
	Set the sid override + authority segments on a real perspective (SaaS only;
	rejects product-derived perspectives with a clear error). Each field is
	optional — null leaves the existing value unchanged. ENABLE/DISABLE override
	writes are rejected when the org is not in ENABLED_FLEXIBLE (D3 / G2).
	"""
	updatePerspectiveSidPurl(uuid: ID!, sidPurlOverride: SidPurlOverride, sidAuthoritySegments: [String!]): Perspective
	deletePerspective(uuid: ID!): Perspective
	setPerspectivesOnComponent(componentUuid: ID!, perspectiveUuids: [ID!]!): Component
	"""
	SaaS-only. Creates a component or product and atomically assigns it to the given
	perspective. Requires WRITE permission on the perspective. Only real perspectives
	(PerspectiveType.PERSPECTIVE) are allowed — product-derived perspectives are rejected.
	Perspective org must match component's target org (enforced by authorization).
	"""
	createComponentInPerspective(component: CreateComponentInput!, perspectiveUuid: ID!): Component
	
	# Enrichment
	triggerEnrichment(artifact: ID!): EnrichmentTriggerResult
	
	# DTrack
	refreshDtrackProjects(orgUuid: ID!): Boolean
	cleanupDtrackProjects(orgUuid: ID!): Boolean
	recleanupDtrackProjects(orgUuid: ID!): Boolean
	syncDtrackProjects(orgUuid: ID!): Boolean

	# Instances
	createInstance(orgUuid: ID!, name: String, instanceType: InstanceType, namespace: String, uri: String!, environment: String, clusterId: ID): Instance
	createInstanceFromDto(instance: CreateInstanceInput!, plan: UpdateInstancePlanInput): Instance
	updateInstance(instance: InstanceInput!): Instance
	setInstanceApiKey(instanceUuid: ID!): ApiKeyForUser
	generateProductRelease(instanceUuid: ID!): [InstanceProductMapActual]
	instData(instance: InstanceDataInput!): Object
	archiveInstance(instanceUuid: ID!): Boolean
	setInstanceSealedSecretCert(sealedCert: String!): Boolean
	# Switch a deployed product on the instance plan from its current
	# feature set to a different one (the new feature set must belong to
	# the same product). FREEFORM-only; requires DEVOPS_WRITE on the
	# instance (or its parent cluster). namespace is required for
	# STANDALONE_INSTANCE and CLUSTER instances (the (product, namespace)
	# pair uniquely identifies a deployment on the plan); for
	# CLUSTER_INSTANCE it is pinned to the instance's own namespace and
	# any value passed is ignored. Pass either instanceUuid or
	# instanceUri (looked up against the FREEFORM key's org) to identify
	# the instance.
	switchInstanceProductFeatureSet(instanceUuid: ID, instanceUri: String, productUuid: ID!, featureSetUuid: ID!, namespace: String): Instance

	# Spin up a new feature set on a PRODUCT with selected dependency-
	# branch overrides applied on top of the BASE feature set's dep
	# config. The new feature set is named after the override branch
	# (the first one when multiple are supplied), gets autoIntegrate=
	# ENABLED, and triggers an auto-integrate run before the call
	# returns. FREEFORM-only; requires VERSION_FEATURESET on the
	# product (READ-or-stronger key type passes — the function itself
	# is the gate).
	versionFeatureSet(productUuid: ID!, overrides: [VersionFeatureSetOverride!]!): Branch

	# properties
	createProperty(property: PropertyInput!): Property

	# secrets
	createSecret(secret: SecretInput!): Secret
	updateSecretDistribution(orgUuid: ID!, secretUuid: ID!, permissions: [PermissionInput]): Secret
	updateSecretDetails( secretUuid: ID!, secret: SecretUpdateInput!): Secret
	deleteSecret(orgUuid: ID!, secretUuid: ID!): Boolean
	
	# BEAR integration
	setBearIntegration(org: ID!, uri: String!, apiKey: String!, skipPatterns: [String]): BearIntegration
	updateBearSkipPatterns(org: ID!, skipPatterns: [String]): BearIntegration
	deleteBearIntegration(org: ID!): Boolean!
}

