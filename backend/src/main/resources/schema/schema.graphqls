# ========== Instance Types ==========

type Instance {
	uuid: ID
	uri: String
	org: ID
	name: String
	# Human-readable identifier resolved server-side. CLUSTER instances are
	# identified by `name`; STANDALONE_INSTANCE / CLUSTER_INSTANCE are
	# identified by `uri`. Falls back to the other field, then to the
	# stringified UUID, so this is always non-empty for any persisted
	# instance.
	displayName: String
	namespace: String
	instanceType: InstanceType
	status: Status
	notes: String
	spawnType: SpawnType
	instances: [ID]
	environment: String
	properties: [InstancePropertyRecord]
	releases: [DeployedRelease]
	targetReleases: [DeployedRelease]
	agentData: String
	productPlans: [InstanceProductMapPlan]
	productActuals: [InstanceProductMapActual]
	createdType: ProgrammaticType
	lastUpdatedBy: ID
	createdDate: DateTime
}

type DeployedRelease {
	timeSent: DateTime
	release: ID
	deliverable: ID
	type: ProgrammaticType
	namespace: String
	properties: Object
	state: ServiceState
	replicas: [DeployedReplica]
	isInError: Boolean
